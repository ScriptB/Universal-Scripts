            while Options.AutoClaimPlaytime.Value do
                for i = 1, 9 do
                    if not Options.AutoClaimPlaytime.Value then break end
                    pcall(function() remoteFunction:InvokeServer("ClaimPlaytime", i) end)
                    task.wait(1)
