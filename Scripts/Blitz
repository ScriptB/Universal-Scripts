-- ═══════════════════════════════════════════════════════════════════
-- PETS TAB — Hatching, Sniping, Auto-Delete
-- ═══════════════════════════════════════════════════════════════════
do
    -- Hatching
    local HatchSection = Tabs.Pets:AddSection("Hatching Controls")

    HatchSection:AddDropdown("SelectedEgg", {
        Title       = "Select Egg",
        Description = "Which egg to hatch in the Auto-Hatch loop.",
        Values      = availableEggs,
        Default     = "Common Egg",
        Callback    = function(v) State.SelectedEgg = v end
    })

    HatchSection:AddSlider("HatchAmount", {
        Title       = "Hatch Amount",
        Description = "Eggs per remote call (1–8 max).",
        Default = 1, Min = 1, Max = 8, Rounding = 0,
        Callback    = function(v) State.HatchAmount = v end
    })

    HatchSection:AddToggle("AutoHatch", {
        Title       = "Auto-Hatch",
        Description = "Fires HatchEgg remote every 0.1 s for the selected egg and amount.",
        Default     = false
    }):OnChanged(function() State.AutoHatch = Options.AutoHatch.Value end)

    HatchSection:AddToggle("FastHatchEggs", {
        Title       = "Fast Hatch (VIM E-Key)",
        Description = "Simulates rapid E-key presses via VirtualInputManager to speed up the hatch UI.",
        Default     = false
    }):OnChanged(function(v)
        Fluent:Notify({ Title = "Fast Hatch", Content = v and "Started" or "Stopped", Duration = 2 })
        if v then task.spawn(function()
            local VIM = game:GetService("VirtualInputManager")
            while Options.FastHatchEggs.Value do
                VIM:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
                task.wait(0.05)
                VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                task.wait(0.05)
            end
        end) end
    end)

    _G.HideHatch = false
    HatchSection:AddToggle("SkipHatchAnimation", {
        Title       = "Skip Hatch Animation",
        Description = "Spoofs game settings to instantly skip the hatching animation. Stealthy & safe.",
        Default     = false
    }):OnChanged(function(v)
        _G.HideHatch = v
        Fluent:Notify({ Title = "Skip Hatch", Content = v and "Enabled (Spoofing Settings)" or "Disabled", Duration = 2 })
    end)

    -- Method 3 Hooking Logic (Only execute the hook once)
    if not _G.BlitzHatchHooked then
        _G.BlitzHatchHooked = true
        task.spawn(function()
            local ok, err = pcall(function()
                local mt = getrawmetatable(game)
                local oldIndex = mt.__index
                setreadonly(mt, false)

                mt.__index = newcclosure(function(t, k)
                    local val = oldIndex(t, k)
                    if _G.HideHatch and k == "Settings" and type(val) == "table" then
                        local spoofedSettings = table.clone(val)
                        spoofedSettings["Skip All Non-Secrets"] = true
                        spoofedSettings["Skip Easy Mythics"] = true
                        return spoofedSettings
                    end
                    return val
                end)

                setreadonly(mt, true)
            end)
            if not ok then
                warn("Failed to hook hatching settings: " .. tostring(err))
            end
        end)
    end

    -- Egg Sniping
    local SnipeSection = Tabs.Pets:AddSection("Egg Sniping")
    SnipeSection:AddParagraph({
        Title = "Pathfinding Warning",
        Content = "Auto Snipe uses Humanoid:MoveTo() — movement is visible to other players. " ..
                  "Disable immediately if an admin joins. Use the Dashboard Killswitch (End)."
    })

    SnipeSection:AddToggle("Snipe4xEggs", {
        Title       = "Auto Snipe 4x Eggs",
        Description = "Scans Workspace for models containing '4x' and 'egg' in their name, walks to them, and hatches. Scans every 3 s.",
        Default     = false
    }):OnChanged(function()
        State.Snipe4xEggs = Options.Snipe4xEggs.Value
        if State.Snipe4xEggs then
            Fluent:Notify({ Title = "4x Sniper ON", Content = "Scanning for 4x eggs...", Duration = 3 })
        end
    end)

    -- Auto-Delete
    local DeleteSection = Tabs.Pets:AddSection("Auto-Delete Pets")
    DeleteSection:AddParagraph({
        Title = "WARNING — Permanent Action",
        Content = "Deletes ALL pets at or below the selected rarity. " ..
                  "Locked pets are always skipped. Equipped pets are unequipped first. " ..
                  "This action CANNOT be undone — verify your threshold before enabling."
    })

    DeleteSection:AddDropdown("DeleteRarityThreshold", {
        Title       = "Delete At Or Below",
        Description = "All pets at this rarity tier and lower will be deleted.",
        Values      = { "Common","Uncommon","Rare","Epic","Legendary" },
        Default     = "Common",
        Save        = true,
        Callback    = function() end
    })

    DeleteSection:AddToggle("DeleteSkipLocked", {
        Title       = "Skip Locked Pets",
        Description = "Always skips pets you have locked in the inventory. Recommended ON.",
        Default     = true,
        Save        = true
    })

    DeleteSection:AddSlider("DeleteDelay", {
        Title       = "Delay Between Deletes (s)",
        Description = "Set to 0 for instant sweep. Increase if you get rate-limited.",
        Default = 0.05, Min = 0, Max = 1, Rounding = 2,
        Save    = true,
        Callback = function() end
    })

    -- Helper: run one delete sweep (shared by button and continuous loop)
    local function runDeleteSweep(fromContinuous)
        local RS         = game:GetService("ReplicatedStorage")
        local threshold  = Options.DeleteRarityThreshold and Options.DeleteRarityThreshold.Value or "Common"
        local skipLocked = (not Options.DeleteSkipLocked) or Options.DeleteSkipLocked.Value
        local delay      = Options.DeleteDelay and Options.DeleteDelay.Value or 0.05
        local threshRank = RARITY_RANK[threshold] or 1

        local ok1, LocalData = pcall(function() return require(RS.Client.Framework.Services.LocalData) end)
        local ok2, PetsData  = pcall(function() return require(RS.Shared.Data.Pets) end)
        if not (ok1 and ok2 and LocalData and PetsData) then
            Fluent:Notify({ Title = "Auto-Delete", Content = "Failed to load data modules.", Duration = 4 })
            return
        end

        local waited = 0
        while not pcall(function() LocalData:Get() end) and waited < 10 do
            task.wait(0.5); waited = waited + 0.5
        end

        local ok3, data = pcall(function() return LocalData:Get() end)
        if not ok3 or not data or not data.Pets then
            Fluent:Notify({ Title = "Auto-Delete", Content = "Inventory not loaded yet.", Duration = 4 })
            return
        end

        local equippedSet = {}
        pcall(function()
            for _, id in ipairs(data.Teams[data.TeamEquipped].Pets) do
                equippedSet[id] = (equippedSet[id] or 0) + 1
            end
        end)

        local deletedStats = {}
        local totalDeleted  = 0
        local skipped       = 0

        for _, pet in ipairs(data.Pets) do
            -- Allow mid-sweep cancellation when running from continuous loop
            if fromContinuous and not (Options.AutoDeleteEnabled and Options.AutoDeleteEnabled.Value) then
                break
            end

            local def = PetsData[pet.Name]
            if not def then skipped = skipped + 1; continue end

            local normRarity = (def.Rarity or ""):gsub("^Limited%s+", "")
            local rank       = RARITY_RANK[normRarity]
            if not rank or rank > threshRank then skipped = skipped + 1; continue end
            if skipLocked and pet.Locked          then skipped = skipped + 1; continue end

            local eqCount = equippedSet[pet.Id] or 0
            for _ = 1, eqCount do
                pcall(function() remoteEvent:FireServer("UnequipPet", pet.Id) end)
                if delay > 0 then task.wait(delay) end
            end

            local amount = pet.Amount or 1
            pcall(function() remoteEvent:FireServer("DeletePet", pet.Id, amount, false) end)

            deletedStats[def.Rarity]          = deletedStats[def.Rarity] or {}
            deletedStats[def.Rarity][pet.Name] = (deletedStats[def.Rarity][pet.Name] or 0) + amount
            totalDeleted = totalDeleted + amount

            if delay > 0 then
                task.wait(delay)
            elseif totalDeleted % 20 == 0 then
                task.wait()
            end
        end

        if totalDeleted > 0 then
            print("\n[BLITZ AUTO-DELETE] Sweep Complete — " .. totalDeleted .. " pets deleted")
            for rty, names in pairs(deletedStats) do
                for n, amt in pairs(names) do
                    print(string.format("[%s] %dx %s", rty, amt, n))
                end
            end
            print("---")
        end

        Fluent:Notify({
            Title = "Auto-Delete " .. (fromContinuous and "(Auto)" or "Done"),
            Content  = string.format("Deleted %d pets. Check F9 for details.", totalDeleted),
            Duration = 5
        })
    end

    DeleteSection:AddButton({
        Title = "Delete Now (One-Shot)",
        Description = "Runs the delete sweep once using your current settings.",
        Callback    = function() task.spawn(runDeleteSweep, false) end
    })

    DeleteSection:AddToggle("AutoDeleteEnabled", {
        Title       = "Auto-Delete (Continuous)",
        Description = "Sweeps inventory every 10 seconds and deletes matching pets.",
        Default     = false,
        Save        = true
    })

    -- Continuous loop
    task.spawn(function()
        while true do
            if Options.AutoDeleteEnabled and Options.AutoDeleteEnabled.Value and remoteEvent then
                runDeleteSweep(true)
            end
            task.wait(10)
        end
    end)

    -- ────────────────────────────────────────────────────────────────
    -- MASS LOCK / UNLOCK PETS
    -- ────────────────────────────────────────────────────────────────
    local MassLockSection = Tabs.Pets:AddSection("Mass Lock / Unlock")
    
    MassLockSection:AddParagraph({
        Title   = "Inventory Management",
        Content = "Lock or unlock all pets of a specific rarity at once. Locked pets are protected from accidental deletions."
    })

    MassLockSection:AddDropdown("MassLockRarity", {
        Title       = "Target Rarity",
        Description = "Which rarity tier to lock/unlock.",
        Values      = { "Common","Unique","Rare","Epic","Legendary","Secret","Celestial","Infinity" },
        Default     = "Common",
        Save        = true,
        Callback    = function() end
    })

    MassLockSection:AddToggle("MassLockShiny", {
        Title       = "Must Be Shiny",
        Description = "If enabled, only shiny variants of the selected rarity will be affected.",
        Default     = false,
        Save        = true
    })

    MassLockSection:AddToggle("MassLockMythic", {
        Title       = "Must Be Mythic",
        Description = "If enabled, only mythic variants of the selected rarity will be affected.",
        Default     = false,
        Save        = true
    })

    MassLockSection:AddToggle("MassLockLimited", {
        Title       = "Must Be Limited",
        Description = "If enabled, only Limited or Event pets of the selected rarity will be affected.",
        Default     = false,
        Save        = true
    })

    local function runMassLock(lockState)
        local RS = game:GetService("ReplicatedStorage")
        local ok1, LocalData = pcall(function() return require(RS.Client.Framework.Services.LocalData) end)
        local ok2, PetsData  = pcall(function() return require(RS.Shared.Data.Pets) end)
        
        if not (ok1 and ok2 and LocalData and PetsData) then
            Fluent:Notify({ Title = "Error", Content = "Could not load Pet Data. Are you in-game?", Duration = 3 })
            return
        end
        
        local data = nil
        pcall(function() data = LocalData:Get() end)
        if not (data and data.Pets) then return end
        
        local targetRarity = Options.MassLockRarity and Options.MassLockRarity.Value or "Common"
        local reqShiny     = Options.MassLockShiny and Options.MassLockShiny.Value
        local reqMythic    = Options.MassLockMythic and Options.MassLockMythic.Value
        local reqLimited   = Options.MassLockLimited and Options.MassLockLimited.Value
        
        local count = 0
        local actionName = lockState and "LockPet" or "UnlockPet"
        
        for _, pet in ipairs(data.Pets) do
            local def = PetsData[pet.Name]
            if not def then continue end
            
            local rawRarity = def.Rarity or pet.Rarity or "Common"
            local rLower = tostring(rawRarity):lower()
            
            -- Check for Limited status before stripping it
            local isLimited = false
            if (def.Limited == true or def.IsLimited == true) or rLower:find("limited") or rLower:find("event") then
                isLimited = true
            end
            
            -- Strip prefixes robustly to get base rarity
            rLower = rLower:gsub("^limited%s+", ""):gsub("^exclusive%s+", ""):gsub("^event%s+", ""):gsub("^shiny%s+", "")
            rLower = rLower:match("^%s*(.-)%s*$") or rLower
            if rLower == "legendary i" or rLower == "legendary ii" or rLower == "legendary iii" then rLower = "legendary" end
            if rLower == "uncommon" then rLower = "unique" end
            
            if rLower ~= targetRarity:lower() then continue end
            
            -- Variant Checks
            local isShiny = pet.Shiny == true or pet.IsShiny == true or (type(pet.Type)=="string" and pet.Type:lower():find("shiny")~=nil) or (type(pet.Variant)=="string" and pet.Variant:lower():find("shiny")~=nil)
            local isMythic = pet.Mythic == true or pet.IsMythic == true or (type(pet.Type)=="string" and pet.Type:lower():find("mythic")~=nil) or (type(pet.Variant)=="string" and pet.Variant:lower():find("mythic")~=nil)
            
            if reqShiny and not isShiny then continue end
            if reqMythic and not isMythic then continue end
            if reqLimited and not isLimited then continue end
            
            -- Skip if already in the desired state
            if pet.Locked == lockState then continue end
            
            -- Use the RemoteEvent to lock/unlock
            pcall(function() remoteEvent:FireServer(actionName, pet.Id, false) end)
            
            count = count + 1
            if count % 20 == 0 then task.wait() end -- Yield to avoid rate limits
        end
        
        Fluent:Notify({
            Title   = lockState and "Mass Lock Complete" or "Mass Unlock Complete",
            Content = string.format("Successfully %s %d %s pets.", lockState and "locked" or "unlocked", count, targetRarity),
            Duration = 5
        })
    end

    MassLockSection:AddButton({
        Title = "Lock Matching Pets",
        Callback = function() task.spawn(runMassLock, true) end
    })

    MassLockSection:AddButton({
        Title = "Unlock Matching Pets",
        Callback = function() task.spawn(runMassLock, false) end
    })
end

-- ═══════════════════════════════════════════════════════════════════
-- WEBHOOKS TAB
-- ═══════════════════════════════════════════════════════════════════
do
    local WebhookSection = Tabs.Webhooks:AddSection("Discord Webhooks")

    WebhookSection:AddInput("HatchWebhook", {
        Title       = "Webhook URL",
        Default     = "",
        Placeholder = "https://discord.com/api/webhooks/...",
        Save        = true,
        Callback    = function(v)
            WebhookConfig.url = v
            if v ~= "" then
                Fluent:Notify({ Title = "Webhook Set", Content = "URL saved.", Duration = 2 })
            end
        end
    })

    WebhookSection:AddToggle("WebhookEnabled", {
        Title       = "Enable Notifications",
        Description = "Send hatch alerts to your Discord webhook when rarity filters match.",
        Default     = false,
        Save        = true
    }):OnChanged(function(v)
        WebhookConfig.enabled = v
        Fluent:Notify({
            Title   = v and " Webhook ON" or " Webhook OFF",
            Content = v and "Notifying for matched rarities." or "Notifications disabled.",
            Duration = 3
        })
    end)

    WebhookSection:AddToggle("WebhookPing", {
        Title       = "Ping User on Notify",
        Description = "Mention your Discord ID in every notification.",
        Default     = false,
        Save        = true
    }):OnChanged(function(v) WebhookConfig.pingUser = v end)

    WebhookSection:AddInput("WebhookPingID", {
        Title       = "Discord User ID",
        Description = "Your 18-digit Discord user ID (e.g. 123456789012345678).",
        Default     = "",
        Placeholder = "12345678...",
        Save        = true,
        Callback    = function(v) WebhookConfig.pingId = v end
    })

    -- Test button
    WebhookSection:AddButton({
        Title = "Send Test Embed",
        Description = "Sends a test embed to verify your webhook URL is correct before you start farming.",
        Callback    = function()
            if not RequestFn then
                Fluent:Notify({ Title = "Unsupported", Content = "Your executor does not support HTTP requests.", Duration = 5 })
                return
            end
            if WebhookConfig.url == "" then
                Fluent:Notify({ Title = "No URL", Content = "Enter a webhook URL first.", Duration = 4 })
                return
            end

            local testPayload = {
                username = "Blitz V2.1  •  Asuneteric",
                avatar_url = "https://tr.rbxcdn.com/53eb9b17fe1432a809c73a13889b5006/420/420/Image/Png",
                embeds = {{
                    title     = "  Webhook Test",
                    color     = 0x57F287,
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
                    description = "Your webhook URL is configured correctly! Blitz V2.1 is ready to send hatch notifications.",
                    fields = {
                        { name = " Player",     value = player.Name,                                    inline = true },
                        { name = " Server",     value = tostring(game.JobId):sub(1,18).."…",           inline = true },
                        { name = " Timestamp",  value = os.date("!%Y-%m-%d %H:%M UTC"),                inline = false},
                    },
                    footer = { text = "Blitz V2.1  •  Asuneteric" },
                }}
            }

            local ok, body = pcall(HttpService.JSONEncode, HttpService, testPayload)
            if not ok then
                Fluent:Notify({ Title = "Encode Error", Content = "Failed to encode test payload.", Duration = 4 })
                return
            end

            local success, res = pcall(function()
                return RequestFn({
                    Url     = WebhookConfig.url,
                    Method  = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body    = body,
                })
            end)

            if success and res then
                local status = tonumber(res.StatusCode) or 0
                if status == 204 or status == 200 then
                    Fluent:Notify({ Title = "Test Sent", Content = "Check your Discord channel!", Duration = 4 })
                else
                    Fluent:Notify({ Title = "HTTP " .. status, Content = "Webhook returned an error. Verify your URL.", Duration = 6 })
                end
            else
                Fluent:Notify({ Title = "Request Failed", Content = "Could not reach Discord. Check your URL.", Duration = 6 })
            end
        end
    })

    -- Rarity filter toggles
    local FilterSection = Tabs.Webhooks:AddSection("Rarity Filters")
    FilterSection:AddParagraph({
        Title   = "Default ON: Secret, Mythic, Celestial, Infinity, Legendary",
        Content = "Toggle each rarity to include or exclude from webhook notifications."
    })

    for _, cfg in ipairs({
        { key = "Infinity",  label = "Infinity"  },
        { key = "Celestial", label = "Celestial" },
        { key = "Secret",    label = "Secret"    },
        { key = "Mythic",    label = "Mythic"    },
        { key = "Legendary", label = "Legendary" },
        { key = "Epic",      label = "Epic"      },
        { key = "Rare",      label = "Rare"      },
        { key = "Uncommon",  label = "Uncommon"  },
        { key = "Common",    label = "Common"    },
    }) do
        FilterSection:AddToggle("WHFilter_" .. cfg.key, {
            Title   = cfg.label,
            Default = WebhookConfig.rarities[cfg.key] or false,
            Save    = true
        }):OnChanged(function(v) WebhookConfig.rarities[cfg.key] = v end)
    end

    -- Heartbeat scanner: watches the Hatching ScreenGui for newly visible frames
    if RequestFn then
        RunService.Heartbeat:Connect(function()
            if not WebhookConfig.enabled then return end
            local gui = player:FindFirstChild("PlayerGui")
            if not gui then return end

            local hf = nil
            for _, sg in ipairs(gui:GetChildren()) do
                if sg:IsA("ScreenGui") then
                    local c = sg:FindFirstChild("Hatching")
                    if c then hf = c; break end
                end
            end
            if not hf then return end

            for _, frame in ipairs(hf:GetChildren()) do
                if not (frame:IsA("Frame") and frame.Visible) then continue end
                if not (frame:FindFirstChild("Label") and frame:FindFirstChild("Rarity")) then continue end

                -- Chance text sanity check (recycled frames often have stale values)
                local chance = frame:FindFirstChild("Chance") and frame.Chance.Text or "N/A"
                if chance == "" or chance == "Label" then continue end

                local rText = frame.Rarity.Text
                -- Strip any rich text formatting just in case
                local strippedText = rText:gsub("<[^>]+>", "")
                
                -- Normalize casing before attempting to strip prefixes
                local rLower = strippedText:lower()
                rLower = rLower:gsub("^limited%s+", "")
                rLower = rLower:gsub("^event%s+", "")
                rLower = rLower:gsub("^shiny%s+", "")
                rLower = rLower:match("^%s*(.-)%s*$") or rLower
                
                if rLower == "???" then rLower = "secret" end

                local isShiny = frame:FindFirstChild("Shiny") and frame.Shiny.Visible or false
                local petName = frame.Label.Text

                -- Check filter
                local isTargeted = false
                for rarity, enabled in pairs(WebhookConfig.rarities) do
                    if enabled and rLower == rarity:lower() then
                        isTargeted = true; break
                    end
                end

                if isTargeted then
                    enqueueWebhook(petName, strippedText, isShiny, chance)
                end
            end
        end)
    end
end

