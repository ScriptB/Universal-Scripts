-- ═══════════════════════════════════════════════════════════════════
-- LOGIC MODULES
-- ═══════════════════════════════════════════════════════════════════

-- UUID Extraction Helper
local function extractItemID(collectible)
    local MIN_UUID_LENGTH = 20
    local FALLBACK_UUID   = "f5577385-2ca4-4259-87c0-75c73580b2c7"

    -- Blacklist check
    local nameLower = string.lower(collectible.Name)
    local blacklist = {"pet","egg","shop","merchant","npc","portal","zone","teleport","machine","orb","coin","gem"}
    for _, word in ipairs(blacklist) do
        if string.find(nameLower, word) then return nil end
    end
    if collectible:GetAttribute("Pet") or collectible:GetAttribute("Owner") or collectible:GetAttribute("Egg") then
        return nil
    end

    local function isValidUUID(str)
        return type(str) == "string" and #str >= MIN_UUID_LENGTH and not string.find(str, ":")
    end

    for _, child in ipairs(collectible:GetChildren()) do
        if child:IsA("StringValue") and isValidUUID(child.Value) then return child.Value end
    end
    for _, attrValue in pairs(collectible:GetAttributes()) do
        if isValidUUID(attrValue) then return attrValue end
    end
    if isValidUUID(collectible.Name) then return collectible.Name end

    return FALLBACK_UUID
end

-- ── Auto-Collect (Decoupled Producer/Consumer) ───────────────────
task.spawn(function()
    local processedUUIDs      = {}
    local collectionQueue     = {}
    local queueSet            = {}
    local lastDiscovery       = 0
    local collectibleContainers = {}

    local CONTAINER_BLACKLIST = {"pet","egg","shop","merchant","npc","portal","zone","teleport","machine"}

    local function updateContainers()
        local rendered = Workspace:FindFirstChild("Rendered")
        if not rendered then collectibleContainers = {}; return end
        local new = {}
        for _, container in ipairs(rendered:GetChildren()) do
            if container:IsA("Folder") or container:IsA("Model") then
                local nl = string.lower(container.Name)
                local safe = true
                for _, w in ipairs(CONTAINER_BLACKLIST) do
                    if string.find(nl, w) then safe = false; break end
                end
                if safe and not string.find(container.Name, ":") and not container:GetAttribute("Pet") and not container:GetAttribute("Egg") then
                    table.insert(new, container)
                end
            end
        end
        collectibleContainers = new
    end

    -- Producer
    task.spawn(function()
        while true do
            if Options.AutoCollect and Options.AutoCollect.Value then
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    if tick() - lastDiscovery > 1.5 then
                        updateContainers()
                        lastDiscovery = tick()
                    end
                    local itemsScanned = 0
                    for _, container in ipairs(collectibleContainers) do
                        if not Options.AutoCollect.Value then break end
                        if not container.Parent then continue end
                        for _, collectible in ipairs(container:GetChildren()) do
                            if not Options.AutoCollect.Value then break end
                            if not collectible.Parent then continue end
                            itemsScanned = itemsScanned + 1
                            if itemsScanned % 100 == 0 then task.wait() end

                            local itemID = extractItemID(collectible)
                            if not itemID or processedUUIDs[itemID] or queueSet[itemID] then continue end

                            local pos = collectible:IsA("BasePart") and collectible.Position
                                     or (collectible:IsA("Model") and (
                                            (collectible.PrimaryPart and collectible.PrimaryPart.Position) or
                                            (collectible:FindFirstChildWhichIsA("BasePart") and collectible:FindFirstChildWhichIsA("BasePart").Position)
                                        ))
                            if pos then
                                local dist = (pos - root.Position).Magnitude
                                if dist <= State.CollectDistance then
                                    table.insert(collectionQueue, { id = itemID, inst = collectible, p = pos })
                                    queueSet[itemID] = true
                                end
                            end
                        end
                    end
                end
            else
                table.clear(collectionQueue)
                table.clear(queueSet)
            end
            task.wait(0.1)
        end
    end)

    -- Consumer
    task.spawn(function()
        while true do
            if Options.AutoCollect and Options.AutoCollect.Value and #collectionQueue > 0 then
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root and (collectRemote or remoteEvent) then
                    table.sort(collectionQueue, function(a, b)
                        return (a.p - root.Position).Magnitude < (b.p - root.Position).Magnitude
                    end)
                    local item = table.remove(collectionQueue, 1)
                    queueSet[item.id] = nil

                    if item.inst.Parent then
                        local currentDist = (item.p - root.Position).Magnitude
                        if currentDist <= State.CollectDistance then
                            processedUUIDs[item.id] = tick()
                            pcall(function()
                                local targetRemote = collectRemote or remoteEvent
                                targetRemote:FireServer(item.id)
                            end)
                            -- Destroy Model feature: Completely de-cache the collectible and its hitboxes
                            pcall(function()
                                local obj = item.inst
                                if obj.Parent and obj.Parent:IsA("Model") and obj.Parent.Name == obj.Name then
                                    obj.Parent:Destroy()
                                else
                                    obj:Destroy()
                                end
                            end)
                            task.wait(tonumber(State.CollectSpeed) or 0.05)
                        end
                    end
                else
                    task.wait(0.05)
                end
            else
                task.wait(0.05)
            end
        end
    end)

    -- Memory cleanup (faster interval to keep table lean on heavy sessions)
    task.spawn(function()
        while true do
            task.wait(30)
            local now = tick()
            for id, ts in pairs(processedUUIDs) do
                if now - ts > 60 then processedUUIDs[id] = nil end
            end
            -- Prune expired webhook cooldowns too
            for id, ts in pairs(WHCooldowns) do
                if now - ts > WH_COOLDOWN_SECS * 2 then WHCooldowns[id] = nil end
            end
        end
    end)
end)

-- ── Auto-Craft Potions ─────────────────────────────────────────────
task.spawn(function()
    local potions = {"Lucky","Speed","Coins","Mythic","Tickets"}
    while true do
        if State.AutoCraftPotions then
            for _, potionName in ipairs(potions) do
                if not State.AutoCraftPotions then break end
                for level = 1, 6 do
                    if not State.AutoCraftPotions then break end
                    pcall(function() remoteEvent:FireServer("CraftPotion", potionName, level, true) end)
                    task.wait(0.1)
                end
            end
        end
        task.wait(5)
    end
end)

-- ── Auto-Use Potions ───────────────────────────────────────────────
-- Seeds lastUsed to 0 so the first toggle fires the remote immediately
-- rather than waiting the full duration before the first use.
task.spawn(function()
    local POTION_MAP = {
        Pot_SecretElixir   = { args = {"UsePotion","Secret Elixir",1},    dur = 10*60 },
        Pot_InfinityElixir = { args = {"UsePotion","Infinity Elixir",1},  dur = 5*60  },
        Pot_EggElixir      = { args = {"UsePotion","Egg Elixir",1},       dur = 20*60 },
        Pot_LuckyInf       = { args = {"UsePotion","Lucky Infinity",1},   dur = 30*60 },
        Pot_LuckyEvo       = { args = {"UsePotion","Lucky Evolved",1},    dur = 23*60 },
        Pot_MythicInf      = { args = {"UsePotion","Mythic Infinity",1},  dur = 30*60 },
        Pot_MythicEvo      = { args = {"UsePotion","Mythic Evolved",1},   dur = 23*60 },
        Pot_SpeedInf       = { args = {"UsePotion","Speed Infinity",1},   dur = 30*60 },
        Pot_SpeedEvo       = { args = {"UsePotion","Speed Evolved",1},    dur = 23*60 },
        Pot_CoinsInf       = { args = {"UsePotion","Coins Infinity",1},   dur = 30*60 },
        Pot_CoinsEvo       = { args = {"UsePotion","Coins Evolved",1},    dur = 23*60 },
        Pot_GoldenOrb      = { args = {"UseGoldenOrb"},                   dur = 5*60  },
    }

    -- Seeded to 0: (tick() - 0) >= (dur - 10) is true immediately on first check
    local lastUsed = {}
    for optId in pairs(POTION_MAP) do lastUsed[optId] = 0 end

    while true do
        if remoteEvent then
            for optId, cfg in pairs(POTION_MAP) do
                local opt = Options[optId]
                if opt and opt.Value then
                    if tick() - lastUsed[optId] >= (cfg.dur - 10) then
                        pcall(function() remoteEvent:FireServer(table.unpack(cfg.args)) end)
                        lastUsed[optId] = tick()
                    end
                else
                    -- Reset timer when toggled off so it fires immediately on re-enable
                    if lastUsed[optId] ~= 0 and (not opt or not opt.Value) then
                        lastUsed[optId] = 0
                    end
                end
            end
        end
        task.wait(1)
    end
end)

-- ── Auto-Hatch ─────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if State.AutoHatch and State.SelectedEgg and remoteEvent then
            pcall(function()
                remoteEvent:FireServer("HatchEgg", State.SelectedEgg, State.HatchAmount)
            end)
        end
        task.wait(0.1)
    end
end)

-- ── Auto Snipe 4x Eggs ─────────────────────────────────────────────
-- FIX: Lua does not support (?i) regex syntax.
-- Was:  string.gsub(targetEgg.Name, "(?i)4x%s*", "")
-- Now:  strip via lower() pattern match, reconstruct correct-case base name
task.spawn(function()
    local targetEgg = nil
    local lastScan  = 0

    local function strip4xPrefix(name)
        -- Remove leading "4x " (case-insensitive) from the name
        return (name:gsub("^[4][xX]%s*", ""))
    end

    while true do
        if State.Snipe4xEggs then
            local char     = player.Character
            local root     = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChild("Humanoid")

            if root and humanoid and remoteEvent then
                -- Invalidate stale target
                if targetEgg and not targetEgg.Instance.Parent then
                    targetEgg = nil
                end

                -- Rescan every 3 s
                if not targetEgg and tick() - lastScan > 3 then
                    lastScan = tick()
                    local foldersToScan = {}
                    if Workspace:FindFirstChild("Rendered") then table.insert(foldersToScan, Workspace.Rendered) end
                    if Workspace:FindFirstChild("Worlds")   then table.insert(foldersToScan, Workspace.Worlds)   end

                    for _, folder in ipairs(foldersToScan) do
                        for _, obj in ipairs(folder:GetDescendants()) do
                            if obj:IsA("Model") then
                                local nl = string.lower(obj.Name)
                                if string.find(nl, "4x") and string.find(nl, "egg") then
                                    local pos = (obj.PrimaryPart and obj.PrimaryPart.Position)
                                             or (obj:FindFirstChildWhichIsA("BasePart") and obj:FindFirstChildWhichIsA("BasePart").Position)
                                    if pos then
                                        targetEgg = { Instance = obj, Position = pos, Name = obj.Name }
                                        break
                                    end
                                end
                            end
                        end
                        if targetEgg then break end
                    end
                end

                if targetEgg then
                    local dist = (root.Position - targetEgg.Position).Magnitude
                    if dist > 15 then
                        humanoid:MoveTo(targetEgg.Position)
                    else
                        humanoid:MoveTo(root.Position)
                        pcall(function()
                            -- Try the full name ("4x Common Egg") first
                            remoteEvent:FireServer("HatchEgg", targetEgg.Name, State.HatchAmount)
                            -- Also try with the "4x " prefix stripped
                            local baseName = strip4xPrefix(targetEgg.Name)
                            if baseName ~= targetEgg.Name then
                                remoteEvent:FireServer("HatchEgg", baseName, State.HatchAmount)
                            end
                        end)
                        task.wait(0.5)
                    end
                end
            end
        else
            targetEgg = nil
        end
        task.wait(0.1)
    end
end)

-- ── Anti-AFK ───────────────────────────────────────────────────────
task.spawn(function()
    local VirtualUser = game:GetService("VirtualUser")
    player.Idled:Connect(function()
        pcall(function() VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new()) end)
    end)
    while true do
        task.wait(60)
        pcall(function() VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new()) end)
    end
end)

