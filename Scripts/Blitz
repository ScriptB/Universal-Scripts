    local function discoverTeleports()
        local data = {}
        local worldsFolder = Workspace:FindFirstChild("Worlds")
        if not worldsFolder then return data end
        for _, world in ipairs(worldsFolder:GetChildren()) do
            if world:IsA("Folder") then
                data[world.Name] = {}
                local function scanContainer(container, cat)
                    if not container then return end
                    for _, island in ipairs(container:GetChildren()) do
                        local sp = island:FindFirstChild("Spawn")
                                or (island:FindFirstChild("IslandTeleport") and island.IslandTeleport:FindFirstChild("Spawn"))
                        if sp then
                            local label = island.Name
                            if cat == "FastTravel" then label = label .. " (FastTravel)" end
                            data[world.Name][label] = sp:GetFullName()
                        end
                    end
                end
                scanContainer(world:FindFirstChild("FastTravel"), "FastTravel")
                scanContainer(world:FindFirstChild("Islands"),    "Islands")
                scanContainer(world:FindFirstChild("Areas"),      "Areas")
            end
        end
        return data
    end

