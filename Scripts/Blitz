do
    -- Active Farming
    local FarmSection = Tabs.Main:AddSection("Active Farming")

    FarmSection:AddToggle("AutoBubble", {
        Title       = "Auto Bubble",
        Description = "Continuously sends BlowBubble remote calls every 0.1 s.",
        Default     = false
    }):OnChanged(function(v)
        if v then task.spawn(function()
            while Options.AutoBubble.Value do
                pcall(function() remoteEvent:FireServer("BlowBubble") end)
                task.wait(0.1)
            end
        end) end
    end)

    local SellCooldown = 5
    FarmSection:AddSlider("SellCooldown", {
        Title       = "Sell Cooldown (seconds)",
        Description = "How often Auto Sell fires. Lower = faster sales.",
        Min = 5, Max = 100, Default = 5, Rounding = 1,
        Callback    = function(v) SellCooldown = v end
    })

    FarmSection:AddToggle("AutoSell", {
        Title       = "Auto Sell",
