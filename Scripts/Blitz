    end)

    ClaimSection:AddToggle("AutoClaimSeason", {
        Title       = "Auto Claim Season Pass",
        Description = "Rapidly claims season pass rewards via FireServer.",
        Default     = false
    }):OnChanged(function(v)
        if v then task.spawn(function()
            while Options.AutoClaimSeason.Value do
                pcall(function() remoteEvent:FireServer("ClaimSeason") end)
                task.wait(0.01)
            end
        end) end
    end)
end

