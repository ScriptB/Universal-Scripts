-- ═══════════════════════════════════════════════════════════════════
-- WEBHOOK QUEUE SYSTEM
-- ═══════════════════════════════════════════════════════════════════
local RequestFn = (syn and syn.request)
               or (http and http.request)
               or http_request
               or (fluxus and fluxus.request)
               or request

local WebhookQueue      = {}          -- ordered list of payloads to send
local WikiImageCache    = {}          -- filename → resolved CDN URL
local WHCooldowns       = {}          -- "petName|rarity" → last send tick
local WH_COOLDOWN_SECS  = 10         -- minimum seconds between identical pet+rarity pings

-- BGSI Fandom image resolver (with shiny fallback)
local function getBGSIPetImage(rawName, isShiny)
    if not RequestFn then return nil end

    local function wikiEncode(name)
        return (name:gsub("", "_"))
    end

    local candidates = {}
    if isShiny then
        table.insert(candidates, wikiEncode(rawName) .. "_(Shiny)")
    end
    table.insert(candidates, wikiEncode(rawName))

    for _, fileName in ipairs(candidates) do
        if WikiImageCache[fileName] then return WikiImageCache[fileName] end

        local url = nil
        pcall(function()
            local apiUrl = "https://bgs-infinity.fandom.com/api.php"
                .. "?action=query"
                .. "&titles=File:" .. HttpService:UrlEncode(fileName) .. ".png"
                .. "&prop=imageinfo&iiprop=url&format=json"

            local res = RequestFn({ Url = apiUrl, Method = "GET",
                Headers = { Accept = "application/json" } })

            if res and res.Body then
                local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
                if ok and data and data.query and data.query.pages then
                    for _, page in pairs(data.query.pages) do
                        if page.pageid ~= -1
                        and page.imageinfo
                        and page.imageinfo[1] then
                            url = page.imageinfo[1].url
                        end
                    end
                end
            end
        end)

        if url and url ~= "" then
            WikiImageCache[fileName] = url
            return url
        end
    end
    return nil
end

-- Build a rich Discord embed payload
local function buildWebhookPayload(petName, rarity, isShiny, chanceStr)
    local sessionStart = _G._BlitzSessionStart or tick()
    local elapsed      = math.floor(tick() - sessionStart)
    local sessionStr   = string.format("%dh %02dm %02ds",
        math.floor(elapsed / 3600),
        math.floor((elapsed % 3600) / 60),
        elapsed % 60)

    -- Leaderstats snapshot
    local hatches, bubbleSize = "N/A", "N/A"
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        local h = ls:FindFirstChild("Hatches") or ls:FindFirstChild("Hatches")
        local b = ls:FindFirstChild("Bubble")  or ls:FindFirstChild("Bubble") or ls:FindFirstChild("Size")
        if h then hatches    = tostring(h.Value) end
        if b then bubbleSize = tostring(b.Value) end
    end

    -- Locale
    local region = "N/A"
    pcall(function()
        local loc = game:GetService("LocalizationService").SystemLocaleId
        if loc and loc ~= "" then region = loc end
    end)

    -- Rarity styling
    local rarityL     = (rarity or ""):lower():gsub("^limited%s*", "")
    local colour      = RARITY_COLOURS[rarityL] or 0x7289DA
    local shinyBadge  = isShiny and " " or ""
    local displayName = petName .. shinyBadge

    -- Author line
    local authorText
    if isShiny and rarityL == "mythic" then
        authorText = " SHINY MYTHIC HATCHED!"
        colour     = 0xFFD700
    elseif rarityL == "mythic" then
        authorText = " Mythic Hatched"
    elseif rarityL == "secret" then
        authorText = " Secret Pet Hatched!"
    elseif rarityL == "celestial" then
        authorText = " Celestial Hatched"
    elseif rarityL == "infinity" then
        authorText = " Infinity Hatched"
    elseif rarityL == "legendary" then
        authorText = " Legendary Hatched"
    elseif isShiny then
        authorText = " Shiny Hatched"
    else
        authorText = " Hatched — " .. (rarity or "Unknown")
    end

    -- Thumbnail (wiki first, game thumbnail fallback)
    local thumbUrl = getBGSIPetImage(petName, isShiny)
                  or string.format(
                        "https://www.roblox.com/game-thumbnails/thumbnail?gameId=%d&width=150&height=150",
                        game.GameId)

    -- Ping content
    local content = ""
    if WebhookConfig.pingUser and WebhookConfig.pingId ~= "" then
        content = "<@" .. WebhookConfig.pingId .. ">"
    end

    return {
        username   = "Blitz V2.1  •  Asuneteric",
        avatar_url = "https://tr.rbxcdn.com/53eb9b17fe1432a809c73a13889b5006/420/420/Image/Png",
        content    = content,
        embeds = {{
            author    = { name = authorText,
                          icon_url = "https://tr.rbxcdn.com/53eb9b17fe1432a809c73a13889b5006/420/420/Image/Png" },
            title     = displayName,
            color     = colour,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            thumbnail = { url = thumbUrl },
            fields    = {
                { name = " Rarity",      value = rarity or "Unknown",       inline = true  },
                { name = " Drop Chance", value = chanceStr or "N/A",         inline = true  },
                { name = " Shiny",        value = isShiny and "Yes" or "No",  inline = true  },
                { name = " Hatches",     value = hatches,                    inline = true  },
                { name = " Bubble Size", value = bubbleSize,                 inline = true  },
                { name = " Player",      value = player.Name,                inline = true  },
                { name = " Locale",      value = region,                     inline = true  },
                { name = " Server",      value = tostring(game.JobId):sub(1,18).."…", inline = true },
                { name = " Uptime",      value = sessionStr,                 inline = false },
            },
            footer = { text = "Blitz V2.1  •  Asuneteric  •  PlaceId: " .. tostring(game.PlaceId) },
        }}
    }
end

-- Enqueue a webhook send (never fires directly — the consumer thread does)
local function enqueueWebhook(petName, rarity, isShiny, chanceStr)
    if not WebhookConfig.enabled or WebhookConfig.url == "" then return end
    if not RequestFn then return end

    -- Per-identity cooldown (avoids spam when a pet floods the hatch UI rapidly)
    local identity  = (petName or "?") .. "|" .. (rarity or "?")
    local lastPing  = WHCooldowns[identity] or 0
    if tick() - lastPing < WH_COOLDOWN_SECS then return end
    WHCooldowns[identity] = tick()

    local ok, payload = pcall(buildWebhookPayload, petName, rarity, isShiny, chanceStr)
    if ok and payload then
        table.insert(WebhookQueue, payload)
    end
end

-- Webhook consumer: sends one payload at a time with retry + rate-limit back-off
task.spawn(function()
    while true do
        if #WebhookQueue > 0 and RequestFn and WebhookConfig.url ~= "" then
            local payload = table.remove(WebhookQueue, 1)
            local body    = nil
            pcall(function() body = HttpService:JSONEncode(payload) end)

            if body then
                local attempts = 0
                local sent     = false

                while attempts < 3 and not sent do
                    attempts = attempts + 1
                    local ok, res = pcall(function()
                        return RequestFn({
                            Url     = WebhookConfig.url,
                            Method  = "POST",
                            Headers = { ["Content-Type"] = "application/json" },
                            Body    = body,
                        })
                    end)

                    if ok and res then
                        local status = tonumber(res.StatusCode) or 0
                        if status == 204 or status == 200 then
                            sent = true
                        elseif status == 429 then
                            -- Respect Discord's Retry-After (default 2 s if header absent)
                            local retryAfter = 2
                            pcall(function()
                                local h = res.Headers or {}
                                local ra = h["retry-after"] or h["Retry-After"]
                                if ra then retryAfter = tonumber(ra) or 2 end
                            end)
                            task.wait(retryAfter + 0.1)
                        else
                            -- 4xx client error — no point retrying
                            if status >= 400 and status < 500 then
                                Fluent:Notify({ Title = "Webhook Error",
                                    Content = "HTTP " .. status .. " — check your URL.",
                                    Duration = 6 })
                                break
                            end
                            task.wait(1 * attempts) -- exponential back-off for 5xx
                        end
                    else
                        task.wait(1 * attempts)
                    end
                end
            end

            task.wait(0.6) -- slight gap between sends to stay comfortably under rate limits
        else
            task.wait(0.5)
        end
    end
end)

-- ═══════════════════════════════════════════════════════════════════
-- DASHBOARD TAB
-- ═══════════════════════════════════════════════════════════════════
do
    local _sessionStart    = tick()
    _G._BlitzSessionStart  = _sessionStart

    local StatusSection = Tabs.Dashboard:AddSection("Live Status")

    local function buildStatus()
        local elapsed  = math.floor((tick() - _sessionStart) / 60)
        local secs     = math.floor((tick() - _sessionStart) % 60)
        local active   = {}
        local checks   = {
            { "AutoCollect",   " Vacuum"      },
            { "AutoHatch",     " Hatch"        },
            { "Snipe4xEggs",   " 4x Snipe"    },
            { "AutoBubble",    " Bubble"       },
            { "AutoSell",      " Sell"         },
            { "HatchMode",     " Hatch Pots"  },
            { "GrindMode",     " Grind Pots"  },
            { "WebhookEnabled"," Webhook"      },
        }
        for _, c in ipairs(checks) do
            if Options[c[1]] and Options[c[1]].Value then
                table.insert(active, c[2])
            end
        end
        local moduleStr = #active > 0 and table.concat(active, "  ") or "None — all systems idle"
        return string.format(
            "  Session: %dm %02ds\n  Anti-AFK: Active\n  Webhook Queue: %d\n\n Running:\n%s",
            elapsed, secs, #WebhookQueue, moduleStr)
    end

    local StatusPara = StatusSection:AddParagraph({ Title = "System Status", Content = buildStatus() })
    task.spawn(function()
        while true do
            task.wait(5)
            pcall(function() StatusPara:Set({ Title = "System Status", Content = buildStatus() }) end)
        end
    end)

    -- Master Killswitch
    StatusSection:AddKeybind("KillswitchKey", {
        Title       = "Master Killswitch",
        Description = "Instantly halts ALL automation. Use if stuck in a teleport loop or an admin joins.",
        Default     = "End",
        Callback    = function()
            State.AutoCollect      = false
            State.AutoHatch        = false
            State.Snipe4xEggs      = false
            State.AutoCraftPotions = false
            State.HatchMode        = false
            State.GrindMode        = false
            local keys = {
                "AutoCollect","AutoHatch","Snipe4xEggs","AutoCraftPotions",
                "HatchMode","GrindMode","AutoBubble","AutoSell",
                "AutoClaimPlaytime","AutoClaimSeason","AutoSpinTickets",
                "AutoFestivalTickets","AutoMysteryBox","AutoBuyAlien",
                "AutoBuyBlackmarket","AutoBuyDice","AutoBuyFestival",
                "AutoBuyFlavours","AutoBuyStorage","AutoUpgradeMastery",
                "AutoRollDice","MiniHyperDarts","MiniRobotClaw",
                "MiniCartEscape","MiniPetMatch","AdminEggTP","FastHatchEggs",
                "AutoDeleteEnabled","WebhookEnabled",
            }
            for _, k in ipairs(keys) do
                if Options[k] then pcall(function() Options[k]:Set(false) end) end
            end
            WebhookConfig.enabled = false
            table.clear(WebhookQueue)
            Fluent:Notify({ Title = "KILLSWITCH", Content = "All automation halted.", Duration = 5 })
        end
    })

    -- Quick Actions
    local ActionsSection = Tabs.Dashboard:AddSection("Quick Actions")
    ActionsSection:AddButton({
        Title = "Copy Discord",
        Description = "Join the community — discord.gg/Mcg3aE2xz4",
        Callback    = function()
            setclipboard("https://discord.gg/Mcg3aE2xz4")
            Fluent:Notify({ Title = "Copied!", Content = "Discord invite copied to clipboard.", Duration = 2 })
        end
    })

    ActionsSection:AddButton({
        Title = "Redeem All Codes",
        Description = "Scans game data for active promo codes and redeems them automatically.",
        Callback    = function()
            Window:Dialog({
                Title   = "Redeem All Codes",
                Content = "Attempt to redeem every code found in game files? Used codes are skipped.",
                Buttons = {
                    { Title = "Redeem", Callback = function()
                        local m = ReplicatedStorage:FindFirstChild("Shared")
                                  and ReplicatedStorage.Shared:FindFirstChild("Data")
                                  and ReplicatedStorage.Shared.Data:FindFirstChild("Codes")
                        if m then
                            local ok, codes = pcall(require, m)
                            if ok and type(codes) == "table" then
                                local n = 0
                                for k in pairs(codes) do
                                    pcall(function() remoteFunction:InvokeServer("RedeemCode", k) end)
                                    n = n + 1
                                    task.wait(0.1)
                                end
                                Fluent:Notify({ Title = "Done", Content = n.." code(s) processed.", Duration = 5 })
                            else
                                Fluent:Notify({ Title = "Error", Content = "Failed to load codes module.", Duration = 5 })
                            end
                        else
                            Fluent:Notify({ Title = "Not Found", Content = "Codes module not found.", Duration = 5 })
                        end
                    end },
                    { Title = "Cancel" }
                }
            })
        end
    })

    -- About
    local AboutSection = Tabs.Dashboard:AddSection("About")
    AboutSection:AddParagraph({
        Title   = "Blitz  •  V2.1  •  Asuneteric",
        Content = "Minimize: Left Ctrl  •  Killswitch: End key"
    })
    AboutSection:AddParagraph({
        Title   = "V2.1 — Webhook & Fixes",
        Content = "→ Webhook queue with retry & Discord rate-limit handling\n" ..
                  "→ Richer embeds: bubble size, server ID, place ID footer\n" ..
                  "→ Test Webhook button in Webhooks tab\n" ..
                  "→ Fixed 4x Sniper Lua regex bug ((?i) syntax removed)\n" ..
                  "→ Removed duplicate Egg Teleport UI section\n" ..
                  "→ Potion loop: immediate first-use on toggle (no 30-min wait)\n" ..
                  "→ Auto-Delete sweep exits cleanly when toggle turns off mid-run"
    })
    AboutSection:AddParagraph({
        Title   = "V2.0 — UI & Performance",
        Content = "→ Complete UI Overhaul: New 6-tab layout for better navigation\n" ..
                  "→ Auto-Collect V2: Decoupled producer-consumer queue\n" ..
                  "→ Collectible hitbox de-caching via instance destruction\n" ..
                  "→ Auto-Delete: Fixed Limited skips and zero-delay instant wiping\n" ..
                  "→ Live F9 Developer Console deletion logging and statistics"
    })
end

