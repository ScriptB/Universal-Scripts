                local plusBtn = New("TextButton", {
                    Text             = "+",
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 14,
                    TextColor3       = Theme.SubText,
                    BackgroundColor3 = Theme.PanelAlt,
                    Size             = UDim2.new(0, 24, 1, 0),
                    AnchorPoint      = Vector2.new(1, 0),
                    Position         = UDim2.new(1, 0, 0, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = 2,
                    Parent           = spinWrap,
                })
                Corner(plusBtn, 5)

                local function applyVal(v)
                    v = Clamp(Round(v, rounding), min_, max_)
                    obj.Value = v
                    valLbl.Text = tostring(v) .. suffix
                    _fire(cb, obj._cbs, v)
                end

                minusBtn.MouseButton1Click:Connect(function() applyVal(obj.Value - step) end)
                plusBtn.MouseButton1Click:Connect(function()  applyVal(obj.Value + step)  end)
                _attachHover(minusBtn, Theme.PanelAlt, Theme.ElementHov)
                _attachHover(plusBtn,  Theme.PanelAlt, Theme.ElementHov)

                -- scroll wheel
                spinWrap.InputChanged:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseWheel then
                        applyVal(obj.Value + (i.Position.Z > 0 and step or -step))
                    end
                end)

                function obj:SetValue(v) applyVal(v) end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:GetValue()    return self.Value end
                _attachElementAPI(obj, wrap)
                return obj
            end

            -- ──────────────────────────────────────────────────
            --  COMBO HELPERS  (inspired by multi-control widgets)
            -- ──────────────────────────────────────────────────
            function go:AddToggleKeybind(tIdx, kIdx, opts)
                opts = opts or {}
                local tOpts = opts.Toggle  or {}
                local kOpts = opts.Keybind or {}
                local t = self:AddToggle(tIdx, tOpts)
                local k = self:AddKeybind(kIdx, kOpts)
                return {
                    Toggle  = t,
                    Keybind = k,
                    SetVisible = function(_, v)
                        t:SetVisible(v)
                        k:SetVisible(v)
                    end,
                    Remove = function(_)
                        t:Remove()
                        k:Remove()
                    end,
                }
            end

            function go:AddToggleColorPicker(tIdx, cIdx, opts)
                opts = opts or {}
                local tOpts = opts.Toggle      or {}
                local cOpts = opts.ColorPicker or {}
                local t = self:AddToggle(tIdx, tOpts)
                local c = self:AddColorPicker(cIdx, cOpts)
                return {
                    Toggle      = t,
                    ColorPicker = c,
                    SetVisible = function(_, v)
                        t:SetVisible(v)
                        c:SetVisible(v)
                    end,
                    Remove = function(_)
                        t:Remove()
                        c:Remove()
                    end,
                }
            end

            function go:AddToggleSlider(tIdx, sIdx, opts)
                opts = opts or {}
                local tOpts = opts.Toggle or {}
                local sOpts = opts.Slider or {}
                local t = self:AddToggle(tIdx, tOpts)
                local s = self:AddSlider(sIdx, sOpts)
                return {
                    Toggle = t,
                    Slider = s,
                    SetVisible = function(_, v)
                        t:SetVisible(v)
                        s:SetVisible(v)
                    end,
                    Remove = function(_)
                        t:Remove()
                        s:Remove()
                    end,
                }
            end

            function go:AddToggleDropdown(tIdx, dIdx, opts)
                opts = opts or {}
                local tOpts = opts.Toggle   or {}
                local dOpts = opts.Dropdown or {}
                local t = self:AddToggle(tIdx, tOpts)
                local d = self:AddDropdown(dIdx, dOpts)
                return {
                    Toggle   = t,
                    Dropdown = d,
                    SetVisible = function(_, v)
                        t:SetVisible(v)
                        d:SetVisible(v)
                    end,
                    Remove = function(_)
                        t:Remove()
                        d:Remove()
                    end,
                }
            end

            -- expose groupbox api
            setmetatable(go, go)
            return go
        end -- _newGroupbox

        -- ── tab column helpers ───────────────────────────────
        function tab:AddLeftGroupbox(name)   return _newGroupbox(name, tab._leftCol) end
        function tab:AddRightGroupbox(name)  return _newGroupbox(name, tab._rightCol) end
        function tab:AddFullGroupbox(name)   return _newGroupbox(name, tab._fullCol) end

        -- Tabbox (sub-tabs inside a column, like Linoria)
        local function _newTabbox(parentCol)
            local tbx = {}
            local innerTabs = {}

            local tWrap = New("Frame", {
                BackgroundColor3 = Theme.Panel,
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BorderSizePixel  = 0,
                Parent           = parentCol,
            })
            Corner(tWrap, 8)
            Stroke(tWrap, Theme.Border)

            local tBar = New("Frame", {
                BackgroundColor3 = Theme.PanelAlt,
                Size             = UDim2.new(1, 0, 0, 28),
                BorderSizePixel  = 0,
                Parent           = tWrap,
            })
            New("UICorner", { CornerRadius = UDim.new(0, 8), Parent = tBar })
            New("Frame", {
                BackgroundColor3 = Theme.PanelAlt,
                Size             = UDim2.new(1, 0, 0.5, 0),
                Position         = UDim2.new(0, 0, 0.5, 0),
                BorderSizePixel  = 0,
                Parent           = tBar,
            })
            local tBarList = New("Frame", {
                BackgroundTransparency = 1,
                Size             = UDim2.new(1, 0, 1, 0),
                Parent           = tBar,
            })
            Pad(tBarList, 0, 0, 4, 4)
            List(tBarList, 2, Enum.FillDirection.Horizontal)

            local tContent = New("Frame", {
                BackgroundTransparency = 1,
                Position         = UDim2.new(0, 0, 0, 28),
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                Parent           = tWrap,
            })
            Pad(tContent, 4, 6, 6, 6)

            local activeTbxTab = nil

            function tbx:AddTab(tName)
                local itab = {}
                local ib = New("TextButton", {
                    Text             = tName,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 11,
                    TextColor3       = Theme.MutedText,
                    BackgroundColor3 = Theme.Panel,
                    AutomaticSize    = Enum.AutomaticSize.X,
                    Size             = UDim2.new(0, 0, 1, 0),
                    BorderSizePixel  = 0,
                    Parent           = tBarList,
                })
                Corner(ib, 4)
                Pad(ib, 0, 0, 8, 8)

                local iPage = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 0),
                    AutomaticSize    = Enum.AutomaticSize.Y,
                    Visible          = #innerTabs == 0,
                    Parent           = tContent,
                })
                List(iPage, 5)
                itab._page = iPage
                itab._btn  = ib

                if #innerTabs == 0 then
                    ib.TextColor3       = Theme.Accent
                    ib.BackgroundColor3 = Theme.ElementAct
                    activeTbxTab = itab
                end

                ib.MouseButton1Click:Connect(function()
                    if activeTbxTab then
                        activeTbxTab._page.Visible = false
                        Tween(activeTbxTab._btn, { TextColor3 = Theme.MutedText, BackgroundColor3 = Theme.Panel }, 0.1)
                    end
                    itab._page.Visible = true
                    activeTbxTab = itab
                    Tween(ib, { TextColor3 = Theme.Accent, BackgroundColor3 = Theme.ElementAct }, 0.1)
                end)

                -- inherit groupbox creation methods on the inner tab
                local proxy = _newGroupbox(tName, iPage)
                proxy._wrap.BackgroundTransparency = 1
                local sk = proxy._wrap:FindFirstChildOfClass("UIStroke")
                if sk then sk:Destroy() end
                local hdrFr = proxy._wrap:FindFirstChild("GBHeader")
                if hdrFr then hdrFr.Visible = false end

                for k, v in pairs(proxy) do
                    if type(v) == "function" then itab[k] = v end
                end
                itab._body = proxy._body

                table.insert(innerTabs, itab)
                return itab
            end

            return tbx
        end  -- _newTabbox

        function tab:AddLeftTabbox()  return _newTabbox(tab._leftCol)  end
        function tab:AddRightTabbox() return _newTabbox(tab._rightCol) end

        setmetatable(tab, tab)
        return tab
    end -- AddTab

    table.insert(self._windows, Win)
    setmetatable(Win, Win)
    return Win
end -- CreateWindow

-- End of Passes 1-5 (SaveManager + ThemeManager)

-- ============================================================
--  PASS 3 -- Global cache (idempotent on re-run)
-- ============================================================
_env.AxiUI    = Library

-- ============================================================
--  PASS 4 -- SaveManager
--  Auto-save / multi-profile / delete / built-in UI builder
-- ============================================================
Library.SaveManager = {}
local SM = Library.SaveManager
SM._folder   = Library._configFolder
SM._autoConn = nil
SM._dirty    = false

function SM:SetFolder(path)
    self._folder = path
    Library:SetConfigFolder(path)
end

function SM:Save(name)
    local data = {}
    for idx, obj in pairs(Toggles) do
        data["t_" .. idx] = obj.Value
    end
    for idx, obj in pairs(Options) do
        local v = obj.Value
        if typeof(v) == "Color3" then
            v = { __col = true, r = v.R, g = v.G, b = v.B }
        end
        data["o_" .. idx] = v
    end
    SafeWrite(self._folder .. "/" .. (name or "default") .. ".json", SafeJSON(data))
    self._dirty = false
end

function SM:Load(name)
    local raw = SafeRead(self._folder .. "/" .. (name or "default") .. ".json")
    if not raw then return false end
    local data = SafeParse(raw)
    for k, v in pairs(data) do
        local idx = k:match("^t_(.+)$")
        if idx and Toggles[idx] then
            pcall(function() Toggles[idx]:SetValue(v == true or v == "true") end)
        end
        idx = k:match("^o_(.+)$")
        if idx and Options[idx] then
            pcall(function()
                if type(v) == "table" and v.__col then
                    Options[idx]:SetValue(Color3.new(v.r, v.g, v.b))
                else
                    Options[idx]:SetValue(v)
                end
            end)
        end
    end
    return true
end

function SM:Delete(name)
    pcall(function()
        if typeof(delfile) == "function" then
            delfile(self._folder .. "/" .. (name or "default") .. ".json")
        end
    end)
end

function SM:List()
    local out = {}
    pcall(function()
        if typeof(listfiles) == "function" then
            for _, f in ipairs(listfiles(self._folder)) do
                local n = f:match("([^/\\]+)%.json$")
                if n then table.insert(out, n) end
            end
        end
    end)
    return out
end

-- AutoSave every <interval>s; only writes when dirty.
-- Pass 0 or nil to stop.  Marks dirty on any Toggle/Option change.
function SM:AutoSave(interval, profileName)
    if self._autoConn then
        pcall(function() self._autoConn:Disconnect() end)
        self._autoConn = nil
    end
    if not interval or interval <= 0 then return end
    if not RunService then return end
    local elapsed = 0
    self._autoConn = Library:_connect(RunService.Heartbeat, function(dt)
        elapsed = elapsed + dt
        if elapsed >= interval then
            elapsed = 0
            if self._dirty then
                pcall(function() self:Save(profileName or "autoload") end)
            end
        end
    end)
    for _, obj in pairs(Toggles) do
        pcall(function() if obj.OnChanged then obj:OnChanged(function() self._dirty = true end) end end)
    end
    for _, obj in pairs(Options) do
        pcall(function() if obj.OnChanged then obj:OnChanged(function() self._dirty = true end) end end)
    end
end

-- Drop-in UI builder: call with any groupbox to add save/load controls
function SM:BuildUI(groupbox)
    if not groupbox then return end
    local profileInput = groupbox:AddInput("SM_ProfileName", {
        Text = "Profile Name",
        Default = "autoload",
        PlaceholderText = "profile name",
    })

    local profileDD = groupbox:AddDropdown("SM_ProfileList", {
        Text = "Saved Profiles",
        Values = self:List(),
        AllowSearch = true,
        Default = nil,
    })

    local function getChosenName()
        local typed = (profileInput and profileInput.Value and tostring(profileInput.Value):gsub("^%s+", ""):gsub("%s+$", "")) or ""
        if typed ~= "" then return typed end
        local picked = profileDD and profileDD.Value
        if type(picked) == "string" and picked ~= "" then return picked end
        return "autoload"
    end

    local function refreshProfiles(selectName)
        local names = self:List()
        table.sort(names, function(a, b) return tostring(a):lower() < tostring(b):lower() end)
        profileDD:SetValues(names)
        if selectName and #names > 0 then
            profileDD:SetValue(selectName)
        end
    end

    profileDD:OnChanged(function(v)
        if type(v) == "string" and v ~= "" then
            profileInput:SetValue(v)
        end
    end)

    groupbox:AddButton({ Text = "Refresh Profile List", Func = function()
        refreshProfiles()
        Library:Notify({ Title = "Profiles Refreshed", Content = "Updated profile list", Type = "info", Duration = 2 })
    end })

    groupbox:AddButton({ Text = "Save Profile", Func = function()
        local n = getChosenName()
        self:Save(n)
        refreshProfiles(n)
        Library:Notify({ Title = "Saved", Content = n, Type = "success", Duration = 2 })
    end })

    groupbox:AddButton({ Text = "Load Profile", Func = function()
        local n = getChosenName()
        local ok = self:Load(n)
        if ok then
            profileInput:SetValue(n)
            profileDD:SetValue(n)
        end
        Library:Notify({
            Title    = ok and "Config Loaded" or "Not Found",
            Content  = n,
            Type     = ok and "info" or "error",
            Duration = 2,
        })
    end })

    groupbox:AddButton({ Text = "Delete Profile", Func = function()
        local n = getChosenName()
        if n == "autoload" then
            Library:Notify({ Title = "Protected", Content = "Cannot delete autoload", Type = "error", Duration = 2 })
            return
        end
        Library:Confirm({
            Title = "Delete Profile",
            Content = "Delete profile '" .. tostring(n) .. "'?",
            ConfirmText = "Delete",
            CancelText = "Cancel",
            OnConfirm = function()
                self:Delete(n)
                profileInput:SetValue("autoload")
                refreshProfiles()
                Library:Notify({ Title = "Deleted", Content = n, Type = "warning", Duration = 2 })
            end,
        })
    end })

    groupbox:AddSection("Auto Save")
    groupbox:AddSlider("SM_AutoInterval", {
        Text = "Interval (seconds, 0 = off)",
        Min = 0, Max = 300, Default = 0, Rounding = 0,
        Callback = function(v) self:AutoSave(v > 0 and v or nil, "autoload") end,
    })

    refreshProfiles("autoload")
end

-- ============================================================
--  PASS 5 -- ThemeManager
--  Apply / custom presets / export/import JSON / built-in UI
-- ============================================================
Library.ThemeManager = {}
local TM = Library.ThemeManager
TM._current   = "Default"
TM._listeners = {}

function TM:Apply(name)
    if not Themes[name] then return end
    self._current = name
    Library:SetTheme(name)
    for _, fn in ipairs(self._listeners) do pcall(fn, name) end
end

function TM:GetCurrent() return self._current end
function TM:GetNames()   return Library:GetThemeNames() end

-- Register a custom preset; missing keys inherit from Default
function TM:AddCustom(name, definition)
    local full = {}
    for k, v in pairs(Themes.Default) do full[k] = v end
    for k, v in pairs(definition)     do full[k] = v end
    Themes[name] = full
end

function TM:OnChanged(fn)
    table.insert(self._listeners, fn)
    Library:OnThemeChanged(fn)
end

-- Export the current live Theme as a JSON string
function TM:Export()
    local t = {}
    for k, v in pairs(Theme) do
        t[k] = {
            r = math.floor(v.R * 255 + 0.5),
            g = math.floor(v.G * 255 + 0.5),
            b = math.floor(v.B * 255 + 0.5),
        }
    end
    return SafeJSON(t)
end

-- Parse a JSON string into a preset (optionally apply immediately)
function TM:Import(name, json, apply)
    local data = SafeParse(json)
    local def  = {}
    for k, v in pairs(data) do
        if type(v) == "table" and type(v.r) == "number" then
            def[k] = Color3.fromRGB(v.r, v.g, v.b)
        end
    end
    self:AddCustom(name, def)
    if apply then self:Apply(name) end
    return def
end

-- Write current theme JSON to file (executor writefile)
function TM:ExportToFile(filename)
    local path = (filename or ("AxiUI_theme_" .. self._current)) .. ".json"
    SafeWrite(path, self:Export())
    Library:Notify({ Title = "Theme Exported", Content = path, Type = "success", Duration = 3 })
end

-- Load a theme JSON file, register it, and apply
function TM:ImportFromFile(filename, name, apply)
    local raw = SafeRead(filename)
    if not raw then
        Library:Notify({ Title = "Import Failed", Content = "File not found", Type = "error", Duration = 3 })
        return
    end
    local friendly = name or (filename:match("([^/\\]+)%.json$") or "Imported")
    self:Import(friendly, raw, apply ~= false)
    Library:Notify({ Title = "Theme Imported", Content = friendly, Type = "success", Duration = 3 })
end

-- Drop-in UI builder: call with any groupbox to add theme controls
function TM:BuildUI(groupbox)
    if not groupbox then return end

    local themeDD = groupbox:AddDropdown("TM_ThemePicker", {
        Text     = "Active Theme",
        Values   = self:GetNames(),
        Default  = self._current,
        AllowSearch = true,
        Callback = function(v) self:Apply(v) end,
    })

    local customNameInput = groupbox:AddInput("TM_CustomName", {
        Text = "Custom Theme Name",
        Default = "MyTheme",
        PlaceholderText = "Custom preset name",
    })

    local fileInput = groupbox:AddInput("TM_FileName", {
        Text = "Theme File",
        Default = "AxiUI_theme.json",
        PlaceholderText = "filename.json",
    })

    local importNameInput = groupbox:AddInput("TM_ImportName", {
        Text = "Imported Theme Name",
        Default = "Imported",
        PlaceholderText = "Optional display name",
    })

    local function refreshThemes(selectName)
        local names = self:GetNames()
        table.sort(names, function(a, b) return tostring(a):lower() < tostring(b):lower() end)
        themeDD:SetValues(names)
        if selectName and Themes[selectName] then
            themeDD:SetValue(selectName)
        elseif self._current and Themes[self._current] then
            themeDD:SetValue(self._current)
        end
    end

    groupbox:AddButton({ Text = "Refresh Theme List", Func = function()
        refreshThemes()
        Library:Notify({ Title = "Themes Refreshed", Content = "Updated theme list", Type = "info", Duration = 2 })
    end })

    groupbox:AddButton({ Text = "Save Current As Custom", Func = function()
        local n = (customNameInput.Value and tostring(customNameInput.Value):gsub("^%s+",""):gsub("%s+$",""))
        if not n or n == "" then n = "MyTheme" end
        local def = {}
        for k, v in pairs(Theme) do def[k] = v end
        self:AddCustom(n, def)
        self:Apply(n)
        refreshThemes(n)
        Library:Notify({ Title = "Custom Theme Saved", Content = n, Type = "success", Duration = 2 })
    end })

    groupbox:AddButton({ Text = "Export Theme to File", Func = function()
        local f = (fileInput.Value and tostring(fileInput.Value):gsub("^%s+",""):gsub("%s+$",""))
        if not f or f == "" then f = "AxiUI_theme_" .. tostring(self._current or "Default") .. ".json" end
        self:ExportToFile(f:gsub("%.json$", ""))
    end })

    groupbox:AddButton({ Text = "Import Theme From File", Func = function()
        local f = (fileInput.Value and tostring(fileInput.Value):gsub("^%s+",""):gsub("%s+$",""))
        if not f or f == "" then
            Library:Notify({ Title = "Import Failed", Content = "Theme file is empty", Type = "error", Duration = 2 })
            return
        end
        local n = (importNameInput.Value and tostring(importNameInput.Value):gsub("^%s+",""):gsub("%s+$",""))
        if n == "" then n = nil end
        self:ImportFromFile(f, n, true)
        refreshThemes(n or self._current)
    end })

    groupbox:AddButton({ Text = "Copy Theme JSON", Func = function()
        local raw = self:Export()
        local ok = pcall(function()
            if setclipboard then
                setclipboard(raw)
            elseif toclipboard then
                toclipboard(raw)
            else
                error("clipboard unsupported")
            end
        end)
        Library:Notify({
            Title = ok and "Copied" or "Copy Failed",
            Content = ok and "Theme JSON copied to clipboard" or "Clipboard function unavailable",
            Type = ok and "success" or "warning",
            Duration = 2,
        })
    end })

    refreshThemes(self._current)
end

-- Final export
return Library
