-- Notifications
Library.Managers.Notification = { _queue = {}, _active = false }
function Library.Managers.Notification:Notify(opts)
    table.insert(self._queue, opts); self:ProcessQueue()
end
function Library.Managers.Notification:ProcessQueue()
    if self._active or #self._queue == 0 then return end
    self._active = true; local opts = table.remove(self._queue, 1); Library:Notify(opts)
    task.delay((opts.Duration or 4) + 0.5, function() self._active = false; self:ProcessQueue() end)
end

