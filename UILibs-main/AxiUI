    function Localization:GetLanguages() local out = {} for k in pairs(self._languages) do table.insert(out, k) end return out end
    Library.Managers.Localization = Localization
-- ── Sound ─────────────────────────────────────────────────────
-- Module-level sound config; Library.Sounds aliases this at runtime.
-- Set any ID to 0 to silence that event. All IDs are rbxassetid numbers.
local _sounds = {
    Toggle  = 0,   -- played when a toggle changes state
    Click   = 0,   -- played on button press
    Notify  = 0,   -- played when a notification appears
    Hover   = 0,   -- played on element hover (use sparingly)
    Open    = 0,   -- played when the window is shown
}

local function PlaySound(id, vol, pitch)
    if not id or id == 0 then return end
    pcall(function()
        local s = Instance.new("Sound")
        s.SoundId          = "rbxassetid://" .. tostring(id)
        s.Volume           = vol   or 0.5
        s.PlaybackSpeed    = pitch or 1
        s.RollOffMaxDistance = 0
        if SoundService then s.Parent = SoundService end
        s:Play()
        if Debris then Debris:AddItem(s, 3)
        else task.delay(3, function() pcall(function() s:Destroy() end) end) end
    end)
end

-- ── GUI container ─────────────────────────────────────────────
local function GetRoot()
    local ok, r = pcall(function()
        if typeof(gethui) == "function" then return gethui() end
        return CoreGui
    end)
    -- Final fallback: game.CoreGui accessed directly (some executors allow this)
    if ok and r then return r end
    local ok2, cg = pcall(function() return game.CoreGui end)
    return ok2 and cg or game:GetService("CoreGui")
end

-- ── Config helpers (uses writefile / readfile if available) ───
local function SafeWrite(path, data)
    pcall(function()
        if typeof(writefile) == "function" then writefile(path, data) end
    end)
end
local function SafeRead(path)
    local ok, d = pcall(function()
        if typeof(readfile) == "function" then return readfile(path) end
        return nil
    end)
    return ok and d or nil
end
local function SafeJSON(t)
    if not HttpService then return "{}" end
    local ok, s = pcall(function() return HttpService:JSONEncode(t) end)
    return ok and s or "{}"
end
local function SafeParse(s)
    if not HttpService then return {} end
    local ok, t = pcall(function() return HttpService:JSONDecode(s) end)
    return ok and t or {}
end

