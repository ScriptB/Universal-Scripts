end

local function Gradient(p, a, b, rot)
    return New("UIGradient", {
        Color    = ColorSequence.new(a, b),
        Rotation = rot or 0,
        Parent   = p,
    })
end

local function Clamp(v, lo, hi)  return math.max(lo, math.min(hi, v)) end
local function Round(v, dp)
    if (dp or 0) == 0 then return math.floor(v + 0.5) end
    local f = 10 ^ dp; return math.floor(v * f + 0.5) / f
end
local function Lerp(a, b, t)     return a + (b - a) * t end

-- Fire a primary callback + all OnChanged listeners in one call.
-- Avoids repeating the same pcall(cb,...) + for-loop in every control.
local function _fire(cb, cbs, ...)
    pcall(cb, ...)
    for _, f in ipairs(cbs) do pcall(f, ...) end
end

-- Standard MouseEnter/Leave hover tinting helper.
local function _attachHover(guiObj, normalColor, hoverColor)
    guiObj.MouseEnter:Connect(function() Tween(guiObj, { BackgroundColor3 = hoverColor or Theme.ElementHov }, 0.08) end)
    guiObj.MouseLeave:Connect(function() Tween(guiObj, { BackgroundColor3 = normalColor or Theme.Element    }, 0.08) end)
end

-- ── Draggable ─────────────────────────────────────────────────
-- Pure 3-signal Connect pattern — zero yields, zero loops.
-- This executor hooks task.wait(), RenderStepped:Wait(), and
-- Signal:Wait() as recursive C callbacks, all of which overflow.
-- Only plain :Connect() callbacks are safe.
--
-- Linoria-inspired ObjPos offset calculation, adapted to signals:
--   handle.InputBegan    → record ObjPos (cursor offset in frame),
--                          snapshot framePos, mark dragging
--   handle.InputChanged  → update dragInput to track the live object
--   UIS.InputChanged     → compute new position from ObjPos + mouse,
--                          write via _safeSetPos
--   input.Changed End    → clear dragging + dragInput
--
-- setrawproperty bypasses __newindex hooks when available.
local _rawSet
do
    local ok, fn = pcall(function() return setrawproperty end)
    if ok and typeof(fn) == "function" then _rawSet = fn end
end
local function _safeSetPos(f, p)
    if _rawSet then
        _rawSet(f, "Position", p)
    else
        f.Position = p
    end
end

local function Draggable(frame, handle, cutoff)
    handle  = handle or frame
    cutoff  = cutoff or (handle == frame and 40 or math.huge)

    frame.Active  = true
    handle.Active = true

    -- Pure-delta drag.  We never modify AnchorPoint, never derive Position
    -- from AbsolutePosition.  We just record the cursor + the frame's
    -- *Position property* on press, then add the pixel delta to its Offset.
    -- This is inset-proof and normalisation-free → zero jump guaranteed.
    local dragging  = false
    local dragInput = nil
    local dragStartMX,  dragStartMY  = 0, 0   -- cursor at press
    local dragStartPos               = frame.Position  -- UDim2 snapshot
    local dragStartAbsX, dragStartAbsY = 0, 0 -- absolute pos at press (for clamp math)
    local dragStartAbsW, dragStartAbsH = 0, 0

    handle.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1
           and input.UserInputType ~= Enum.UserInputType.Touch then return end

        local mX = input.Position.X
        local mY = input.Position.Y
        -- cutoff: only allow grab from the top portion of the frame
        local fAbsY = frame.AbsolutePosition.Y
        if mY - fAbsY > cutoff then return end

        dragStartMX  = mX
        dragStartMY  = mY
        dragStartPos = frame.Position          -- snapshot the UDim2 property
        dragStartAbsX = frame.AbsolutePosition.X
        dragStartAbsY = fAbsY
        dragStartAbsW = frame.AbsoluteSize.X
        dragStartAbsH = frame.AbsoluteSize.Y
        dragging = true

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging  = false
                dragInput = nil
            end
        end)
    end)

    handle.InputChanged:Connect(function(input)
        local t = input.UserInputType
        if t == Enum.UserInputType.MouseMovement
        or t == Enum.UserInputType.Touch then
            dragInput = input
        end

