--- Ensures the theme folder exists.
function ThemeManager:Init()
    if typeof(makefolder) == "function" and not isfolder(self._themeFolder) then
        makefolder(self._themeFolder)
    end
end

--- Saves a theme table to disk as JSON.
function ThemeManager:SaveTheme(name, themeTable)
    self:Init()
    local path = self._themeFolder .. "/" .. name .. ".json"
    local data = HttpService and HttpService:JSONEncode(themeTable) or "{}"
    safe_writefile(path, data)
end

--- Loads a theme table from disk.
function ThemeManager:LoadTheme(name)
    self:Init()
    local path = self._themeFolder .. "/" .. name .. ".json"
    local data = safe_readfile(path)
    if data and HttpService then
        local ok, t = pcall(function() return HttpService:JSONDecode(data) end)
        if ok and type(t) == "table" then return t end
    end
    return nil
end

--- Deletes a saved theme file.
function ThemeManager:DeleteTheme(name)
    self:Init()
    local path = self._themeFolder .. "/" .. name .. ".json"
    safe_delfile(path)
end

--- Lists all saved theme names.
function ThemeManager:ListThemes()
    self:Init()
    local files = safe_listfiles(self._themeFolder)
    local out = {}
    for _, f in ipairs(files) do
        local n = f:match("([^/\\]+)%.json$")
        if n then table.insert(out, n) end
    end
    return out
end

