-- Helper: collect all UI state (Toggles, Options)
function SettingsManager:CollectState()
    local state = { Toggles = {}, Options = {} }
    for k, v in pairs(Toggles) do
        if type(v) == "table" and v.GetValue then
            state.Toggles[k] = v:GetValue()
        end
    end
    for k, v in pairs(Options) do
        if type(v) == "table" and v.GetValue then
            state.Options[k] = v:GetValue()
        end
    end
    return state
end

-- Helper: restore all UI state
function SettingsManager:RestoreState(state)
    if not state then return end
    if state.Toggles then
        for k, v in pairs(state.Toggles) do
            if Toggles[k] and Toggles[k].SetValue then
                Toggles[k]:SetValue(v)
            end
        end
    end
    if state.Options then
        for k, v in pairs(state.Options) do
            if Options[k] and Options[k].SetValue then
                Options[k]:SetValue(v)
            end
        end
    end
end

