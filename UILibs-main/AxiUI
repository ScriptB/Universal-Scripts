--  UI SCALING (accessibility)
-- ══════════════════════════════════════════════════════════════
Library._uiScale = 1

function Library:SetUIScale(scale)
    self._uiScale = math.clamp(scale or 1, 0.5, 2)
    -- Apply scale to all windows
    for _, w in ipairs(self._windows) do
        if w._sg then
            local uiScale = w._sg:FindFirstChildOfClass("UIScale")
            if not uiScale then
                uiScale = Instance.new("UIScale")
                uiScale.Parent = w._sg
            end
            uiScale.Scale = self._uiScale
        end
    end
end

function Library:GetUIScale()
    return self._uiScale
end
