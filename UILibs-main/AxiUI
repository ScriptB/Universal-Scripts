    if not t then return end

    -- Build reverse lookup: "R,G,B" → themeKey  (before mutating Theme)
    local function c2s(c)
        return math.floor(c.R*255+0.5)..","..math.floor(c.G*255+0.5)..","..math.floor(c.B*255+0.5)
    end
    local oldMap = {}
    for k, v in pairs(Theme) do
        local s = c2s(v)
        if not oldMap[s] then oldMap[s] = k end
    end

    -- Update active Theme table in-place
    for k, v in pairs(t) do Theme[k] = v end

    -- Walk every Instance in every open ScreenGui and remap colours
    local props = { "BackgroundColor3", "TextColor3", "ImageColor3" }
    local function repaint(inst)
        pcall(function()
            for _, prop in ipairs(props) do
                local ok, v = pcall(function() return inst[prop] end)
                if ok and typeof(v) == "Color3" then
                    local key = oldMap[c2s(v)]
                    if key then pcall(function() inst[prop] = Theme[key] end) end
                end
            end
            -- UIStroke.Color
            local sk = inst:FindFirstChildOfClass("UIStroke")
            if sk then
                local ok, v = pcall(function() return sk.Color end)
                if ok then
                    local key = oldMap[c2s(v)]
                    if key then pcall(function() sk.Color = Theme[key] end) end
                end
            end
            -- UIGradient.Color (remap each keypoint)
            local gd = inst:FindFirstChildOfClass("UIGradient")
            if gd then
                pcall(function()
                    local kps = gd.Color.Keypoints
                    local changed, newKps = false, {}
                    for i, kp in ipairs(kps) do
                        local key = oldMap[c2s(kp.Value)]
                        newKps[i] = ColorSequenceKeypoint.new(kp.Time, key and Theme[key] or kp.Value)
                        if key then changed = true end
                    end
                    if changed then gd.Color = ColorSequence.new(newKps) end
                end)
            end
        end)
        for _, child in ipairs(inst:GetChildren()) do repaint(child) end
    end

    for _, w in ipairs(self._windows) do
        pcall(function() repaint(w._sg) end)
    end
    if self._wmSG  then pcall(function() repaint(self._wmSG)  end) end
    if self._kbSG  then pcall(function() repaint(self._kbSG)  end) end
    -- (notifications are transient; skip repaint to avoid mid-animation flicker)

    -- fire registered callbacks (e.g. dropdown to update label)
    if self._onThemeChanged then
        for _, fn in ipairs(self._onThemeChanged) do pcall(fn, name) end
    end
end

function Library:OnThemeChanged(fn)
    self._onThemeChanged = self._onThemeChanged or {}
    table.insert(self._onThemeChanged, fn)
end

function Library:GetThemeNames()
    local n = {}
    for k in pairs(Themes) do table.insert(n, k) end
    return n
end

-- ── Config system ─────────────────────────────────────────────
function Library:SetConfigFolder(name)
    self._configFolder = name
    pcall(function()
        if typeof(makefolder) == "function" and not isfolder(name) then
            makefolder(name)
        end
    end)
end

function Library:SaveConfig(name)
    local data = {}
    for idx, obj in pairs(Toggles) do
        data["t_" .. idx] = obj.Value
    end
    for idx, obj in pairs(Options) do
        local v = obj.Value
        if type(v) == "userdata" then   -- Color3
            v = { r = v.R, g = v.G, b = v.B }
        end
        data["o_" .. idx] = v
    end
    local path = self._configFolder .. "/" .. (name or "default") .. ".json"
    SafeWrite(path, SafeJSON(data))
end

function Library:LoadConfig(name)
    local path = self._configFolder .. "/" .. (name or "default") .. ".json"
    local raw  = SafeRead(path)
    if not raw then return end
    local data = SafeParse(raw)
    for k, v in pairs(data) do
        local idx = k:match("^t_(.+)$")
        if idx and Toggles[idx] then
            Toggles[idx]:SetValue(v)
        end
        idx = k:match("^o_(.+)$")
        if idx and Options[idx] then
            local obj = Options[idx]
            if type(v) == "table" and v.r then
                obj:SetValue(Color3.new(v.r, v.g, v.b))
            else
                obj:SetValue(v)
            end
        end
    end
end

function Library:ListConfigs()
    local list = {}
    pcall(function()
        if typeof(listfiles) == "function" then
            for _, f in ipairs(listfiles(self._configFolder)) do
                local n = f:match("([^/\\]+)%.json$")
                if n then table.insert(list, n) end
            end
        end
    end)
    return list
end

