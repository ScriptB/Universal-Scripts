function Library:GetVersion() return self._VERSION end

function Library:_connect(sig, fn)
    local c = sig:Connect(fn)
    table.insert(self._connections, c)
    return c
end

function Library:OnUnload(fn)
    table.insert(self._unloadFns, fn)
end

function Library:Unload()
    if self.Unloaded then return end
    self.Unloaded = true
    for _, fn in ipairs(self._unloadFns) do pcall(fn) end
    for _, c  in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
    for _, w  in ipairs(self._windows) do
        pcall(function() w._sg:Destroy() end)
    end
    if self._notifSG   then pcall(function() self._notifSG:Destroy()    end) end
    if self._wmSG      then pcall(function() self._wmSG:Destroy()       end) end
    if self._kbSG      then pcall(function() self._kbSG:Destroy()       end) end
end

-- ── Theme switching ───────────────────────────────────────────
function Library:SetTheme(name)
    local t = Themes[name]
    if not t then return end
    if self._themeSwitching then return end   -- guard against callback re-entrancy
    self._themeSwitching = true

    -- Build reverse lookup: "R,G,B" → themeKey  (before mutating Theme)
    local function c2s(c)
        return math.floor(c.R*255+0.5)..","..math.floor(c.G*255+0.5)..","..math.floor(c.B*255+0.5)
    end
    local oldMap = {}
    for k, v in pairs(Theme) do
        local s = c2s(v)
        if not oldMap[s] then oldMap[s] = k end
    end

    -- Update active Theme table in-place
    for k, v in pairs(t) do Theme[k] = v end

    -- Walk every Instance using an explicit stack (no recursion).
    -- A deep UI tree can exceed the C call-stack limit if walked recursively.
    local props = { "BackgroundColor3", "TextColor3", "ImageColor3" }

    local function repaintTree(root)
        local stack = { root }
        while #stack > 0 do
            local inst = stack[#stack]
            stack[#stack] = nil

            pcall(function()
                for _, prop in ipairs(props) do
                    local ok, v = pcall(function() return inst[prop] end)
                    if ok and typeof(v) == "Color3" then
                        local key = oldMap[c2s(v)]
                        if key then pcall(function() inst[prop] = Theme[key] end) end
                    end
                end
                -- UIStroke.Color
                local sk = inst:FindFirstChildOfClass("UIStroke")
                if sk then
                    local ok, v = pcall(function() return sk.Color end)
                    if ok then
                        local key = oldMap[c2s(v)]
                        if key then pcall(function() sk.Color = Theme[key] end) end
                    end
                end
                -- UIGradient.Color (remap each keypoint)
                local gd = inst:FindFirstChildOfClass("UIGradient")
                if gd then
                    pcall(function()
                        local kps = gd.Color.Keypoints
                        local changed, newKps = false, {}
                        for i, kp in ipairs(kps) do
                            local key = oldMap[c2s(kp.Value)]
                            newKps[i] = ColorSequenceKeypoint.new(kp.Time, key and Theme[key] or kp.Value)
                            if key then changed = true end
                        end
                        if changed then gd.Color = ColorSequence.new(newKps) end
                    end)
                end
            end)

            for _, child in ipairs(inst:GetChildren()) do
                stack[#stack + 1] = child
            end
        end
    end

    for _, w in ipairs(self._windows) do
        pcall(function() repaintTree(w._sg) end)
    end
    if self._wmSG  then pcall(function() repaintTree(self._wmSG)  end) end
    if self._kbSG  then pcall(function() repaintTree(self._kbSG)  end) end
    if self._notifSG then pcall(function() repaintTree(self._notifSG) end) end

    -- fire registered callbacks (e.g. dropdown to update label)
    if self._onThemeChanged then
        for _, fn in ipairs(self._onThemeChanged) do pcall(fn, name) end
    end

    self._themeSwitching = false
end

function Library:OnThemeChanged(fn)
    self._onThemeChanged = self._onThemeChanged or {}
    table.insert(self._onThemeChanged, fn)
end

function Library:GetThemeNames()
    local n = {}
    for k in pairs(Themes) do table.insert(n, k) end
    return n
end

function Library:GetTheme()
    return Theme
end

function Library:GetThemeValue(key)
    return Theme[key]
end

