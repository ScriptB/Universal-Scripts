                if ok and type(t) == "table" then
                    if t.Toggles then for k, v in pairs(t.Toggles) do if Toggles[k] then pcall(function() Toggles[k]:SetValue(v) end) end end end
                    if t.Options then for k, v in pairs(t.Options) do if Options[k] then pcall(function() Options[k]:SetValue((type(v) == "table" and v.__col) and Color3.new(v.r, v.g, v.b) or v) end) end end end
                end
            end
        end
    end)
