            { Text = "OK", Type = "accent", Callback = fn },
            { Text = "Cancel", Type = "muted", Callback = fn },
        },
        CloseOnBackdrop = true,
    })

    Returns a dialog object with :Close().
]]
function Library:Dialog(opts)
    opts = opts or {}
    local title   = opts.Title or "Dialog"
    local content = opts.Content or ""
    local buttons = opts.Buttons or {
        { Text = "OK", Type = "accent" },
    }
    local closeOnBackdrop = opts.CloseOnBackdrop ~= false

    local sg = New("ScreenGui", {
        Name           = "AxiUI_Dialog",
        ResetOnSpawn   = false,
        IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 10000,
        Parent         = GetRoot(),
    })

    local backdrop = New("TextButton", {
        Text                   = "",
        AutoButtonColor        = false,
        BackgroundColor3       = Theme.Black,
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 1, 0),
        BorderSizePixel        = 0,
        Parent                 = sg,
    })

    local card = New("Frame", {
        BackgroundColor3       = Theme.Panel,
        BackgroundTransparency = 1,
        AnchorPoint            = Vector2.new(0.5, 0.5),
        Position               = UDim2.new(0.5, 0, 0.5, 12),
        Size                   = UDim2.new(0, 380, 0, 0),
        AutomaticSize          = Enum.AutomaticSize.Y,
        BorderSizePixel        = 0,
        Active                 = true,
        Parent                 = backdrop,
    })
    Corner(card, 10)
    Stroke(card, Theme.Border, 1)

    local top = New("Frame", {
        BackgroundColor3 = Theme.PanelAlt,
        Size             = UDim2.new(1, 0, 0, 36),
        BorderSizePixel  = 0,
        Parent           = card,
    })
    New("UICorner", { CornerRadius = UDim.new(0, 10), Parent = top })
    New("Frame", {
        BackgroundColor3 = Theme.PanelAlt,
        Size             = UDim2.new(1, 0, 0.5, 0),
        Position         = UDim2.new(0, 0, 0.5, 0),
        BorderSizePixel  = 0,
        Parent           = top,
    })
    New("TextLabel", {
        Text             = title,
        Font             = Enum.Font.GothamBold,
        TextSize         = 13,
        TextColor3       = Theme.Text,
        TextXAlignment   = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, 12, 0, 0),
        Size             = UDim2.new(1, -24, 1, 0),
        Parent           = top,
    })

    local body = New("Frame", {
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, 0, 0, 36),
        Size             = UDim2.new(1, 0, 0, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        Parent           = card,
    })
    Pad(body, 10, 10, 12, 12)
    List(body, 10)

    New("TextLabel", {
        Text             = content,
        Font             = Enum.Font.Gotham,
        TextSize         = 12,
        TextColor3       = Theme.SubText,
        TextXAlignment   = Enum.TextXAlignment.Left,
        TextWrapped      = true,
        BackgroundTransparency = 1,
        Size             = UDim2.new(1, 0, 0, 0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        Parent           = body,
    })

    local row = New("Frame", {
        BackgroundTransparency = 1,
        Size             = UDim2.new(1, 0, 0, 30),
        Parent           = body,
    })
    List(row, 6, Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Right)

    local closed = false
    local function closeDialog()
        if closed then return end
        closed = true
        Tween(backdrop, { BackgroundTransparency = 1 }, 0.12)
        Tween(card, {
            BackgroundTransparency = 1,
            Position = UDim2.new(0.5, 0, 0.5, 12),
        }, 0.14, Enum.EasingStyle.Quad)
        task.delay(0.16, function() pcall(function() sg:Destroy() end) end)
    end

    for _, b in ipairs(buttons) do
        local bType = b.Type or "accent"
        local txtColor = (bType == "danger" and Theme.Danger)
            or (bType == "warning" and Theme.Warning)
            or (bType == "success" and Theme.Success)
            or (bType == "muted" and Theme.SubText)
            or Theme.Accent

        local btn = New("TextButton", {
            Text             = b.Text or "OK",
            Font             = Enum.Font.GothamBold,
            TextSize         = 12,
            TextColor3       = txtColor,
            BackgroundColor3 = Theme.Element,
            Size             = UDim2.new(0, 0, 1, 0),
            AutomaticSize    = Enum.AutomaticSize.X,
            BorderSizePixel  = 0,
            Parent           = row,
        })
        Corner(btn, 6)
        Pad(btn, 0, 0, 10, 10)

        _attachHover(btn)
        btn.MouseButton1Click:Connect(function()
            pcall(b.Callback or function() end)
            closeDialog()
        end)
    end

    if closeOnBackdrop then
        backdrop.MouseButton1Click:Connect(closeDialog)
    end

    Tween(backdrop, { BackgroundTransparency = 0.45 }, 0.12)
    Tween(card, {
        BackgroundTransparency = 0,
        Position = UDim2.new(0.5, 0, 0.5, 0),
    }, 0.14, Enum.EasingStyle.Quad)

    return { Close = closeDialog }
end

