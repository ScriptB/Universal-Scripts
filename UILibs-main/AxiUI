-- ── Notifications ─────────────────────────────────────────────
Library.NotificationManager = { _queue = {}, _active = false }
function Library.NotificationManager:Notify(opts)
    table.insert(self._queue, opts); self:ProcessQueue()
end
function Library.NotificationManager:ProcessQueue()
    if self._active or #self._queue == 0 then return end
    self._active = true
    local opts = table.remove(self._queue, 1)
    Library:Notify(opts)
    task.delay((opts.Duration or 4) + 0.5, function() self._active = false; self:ProcessQueue() end)
end
function Library.NotificationManager:ClearAll()
    if Library._notifHolder then for _, c in ipairs(Library._notifHolder:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end end
    self._queue = {}; self._active = false
end

-- ── Theme Manager ─────────────────────────────────────────────
Library.ThemeManager = { _current = "Default", _listeners = {} }
function Library.ThemeManager:Apply(name)
    if not Themes[name] then return end
    self._current = name; Library:SetTheme(name)
    for _, fn in ipairs(self._listeners) do pcall(fn, name) end
end
function Library.ThemeManager:GetCurrent() return self._current end
function Library.ThemeManager:GetNames() return Library:GetThemeNames() end
function Library.ThemeManager:AddCustom(name, definition)
    local full = {}
    for k, v in pairs(Themes.Default) do full[k] = v end
    for k, v in pairs(definition) do full[k] = v end
    Themes[name] = full
end

-- ── Save Manager ──────────────────────────────────────────────
Library.SaveManager = { _folder = Library._configFolder, _autoConn = nil, _dirty = false }
function Library.SaveManager:SetFolder(path)
    self._folder = path; Library:SetConfigFolder(path)
end
function Library.SaveManager:Save(name)
    local data = {}
    for idx, obj in pairs(Toggles) do data["t_" .. idx] = obj.Value end
    for idx, obj in pairs(Options) do
        local v = obj.Value
        if typeof(v) == "Color3" then v = { __col = true, r = v.R, g = v.G, b = v.B } end
        data["o_" .. idx] = v
    end
    pcall(function()
        if not isfolder(self._folder) then makefolder(self._folder) end
        SafeWrite(self._folder .. "/" .. (name or "default") .. ".json", SafeJSON(data))
    end)
    self._dirty = false
end
function Library.SaveManager:Load(name)
    local raw = SafeRead(self._folder .. "/" .. (name or "default") .. ".json")
    if not raw then return false end
    local data = SafeParse(raw)
    for k, v in pairs(data) do
        if k:match("^t_") and Toggles[k:sub(3)] then pcall(function() Toggles[k:sub(3)]:SetValue(v == true or v == "true") end)
        elseif k:match("^o_") and Options[k:sub(3)] then
            pcall(function() Options[k:sub(3)]:SetValue((type(v) == "table" and v.__col) and Color3.new(v.r, v.g, v.b) or v) end)
        end
    end
    return true
end
function Library.SaveManager:List()
    local out = {}
    pcall(function()
        if typeof(listfiles) == "function" then
            for _, f in ipairs(listfiles(self._folder)) do
                local n = f:match("([^/\\]+)%.json$")
                if n then table.insert(out, n) end
            end
        end
    end)
    return out
end

