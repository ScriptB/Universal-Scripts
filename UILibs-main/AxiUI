    -- Visibility: single-source-of-truth (_vis) + 150ms spam guard (_tLock)
    -- SetVisible(false): hides frame then disables ScreenGui input gate
    -- SetVisible(true):  re-enables ScreenGui then reveals frame
    -- When hidden: sg.Enabled=false → nothing inside receives any input,
    --   no MouseEnter, no focus, no layout recalculation — perfectly frozen.
    local _vis   = autoShow
    local _tLock = false
    function Win:SetVisible(v)
        _vis = v
        if v then
            sg.Enabled         = true
            shadowWrap.Visible = true
            -- Accent–border flash: tells the user the UI snapped back into place
            Tween(winStroke, { Color = Theme.Accent }, 0)
            task.delay(0.08, function()
                if _vis then Tween(winStroke, { Color = Theme.Border }, 0.5) end
            end)
            PlaySound(_sounds.Open, 0.4, 1.02)
        else
            shadowWrap.Visible = false
            sg.Enabled         = false
        end
    end
    function Win:Show()   self:SetVisible(true)  end
    function Win:Hide()   self:SetVisible(false) end
    function Win:Toggle()
        if _tLock then return end
        _tLock = true
        self:SetVisible(not _vis)
        task.delay(0.15, function() _tLock = false end)
    end
    -- Allow external code (e.g. rebind picker) to change which key fires Toggle.
    function Win:SetToggleKey(k) if k then _tKey.v = k end end
    -- Wire the toggle key — intentionally ignores gameProcessedEvent so the
    -- menu can be dismissed even when a widget inside it has focus.
    UIS.InputBegan:Connect(function(i)
        if i.KeyCode == _tKey.v then Win:Toggle() end
    end)

    -- ── AddTab ───────────────────────────────────────────────
    function Win:AddTab(name, icon)
