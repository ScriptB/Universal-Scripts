function Library:ReloadUI()
    -- Save current state
    local state = Library.SettingsManager:CollectState()
    local theme = {}
    for k, v in pairs(Theme) do theme[k] = v end
    -- Unload current UI
    self:Unload()
    -- Re-require or reload the script (user must provide loader)
    -- This is a placeholder: user should reload their script here
    -- Example: loadstring(readfile("AxiUI_Library.lua"))()
    -- After reload, restore state and theme
    -- Library.SettingsManager:RestoreState(state)
    -- Library:SetTheme(theme)
    -- For safety, just return state and theme for user to handle
    return state, theme
end
