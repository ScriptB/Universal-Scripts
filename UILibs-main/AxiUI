            -- ──────────────────────────────────────────────────
            --  PROGRESS BAR  (animated fill, SetValue)
            -- ──────────────────────────────────────────────────
            function go:AddProgressBar(idx, opts)
                opts = opts or {}
                local text    = opts.Text    or idx
                local min_    = opts.Min     or 0
                local max_    = opts.Max     or 100
                local default = opts.Default or min_
                local suffix  = opts.Suffix  or ""
                local barColor= opts.Color   or Theme.Accent
                local cb      = opts.Callback or function() end

                local obj = { Value = default, _cbs = {} }
                Options[idx] = obj

                local wrap = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 38),
                    Parent           = body,
                })
                local topRow = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 16),
                    Parent           = wrap,
                })
                New("TextLabel", {
                    Text             = text,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 11,
                    TextColor3       = Theme.SubText,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, -50, 1, 0),
                    Parent           = topRow,
                })
                local valLbl = New("TextLabel", {
                    Text             = tostring(default) .. suffix,
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 11,
                    TextColor3       = Theme.Accent,
                    TextXAlignment   = Enum.TextXAlignment.Right,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(0, 48, 1, 0),
                    Position         = UDim2.new(1, -48, 0, 0),
                    Parent           = topRow,
                })
                local track = New("Frame", {
                    BackgroundColor3 = Theme.SliderTrack,
                    Size             = UDim2.new(1, 0, 0, 8),
                    Position         = UDim2.new(0, 0, 0, 20),
                    BorderSizePixel  = 0,
                    Parent           = wrap,
                })
                Corner(track, 4)
                local rel0 = (default - min_) / math.max(max_ - min_, 0.001)
                local fill = New("Frame", {
                    BackgroundColor3 = barColor,
                    Size             = UDim2.new(rel0, 0, 1, 0),
                    BorderSizePixel  = 0,
                    Parent           = track,
                })
                Corner(fill, 4)

                function obj:SetValue(v)
                    v = Clamp(v, min_, max_)
                    self.Value = v
                    local rel = (v - min_) / math.max(max_ - min_, 0.001)
                    Tween(fill, { Size = UDim2.new(rel, 0, 1, 0) }, 0.18, Enum.EasingStyle.Quart)
                    valLbl.Text = tostring(v) .. suffix
                    pcall(cb, v)
                    for _, f in ipairs(self._cbs) do pcall(f, v) end
                end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                return obj
            end

