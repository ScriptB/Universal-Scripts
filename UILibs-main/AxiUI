-- Module-level sound config; Library.Sounds aliases this at runtime.
-- Set any ID to 0 to silence that event. All IDs are rbxassetid numbers.
local _sounds = {
    Toggle  = 0,   -- played when a toggle changes state
    Click   = 0,   -- played on button press
    Notify  = 0,   -- played when a notification appears
    Hover   = 0,   -- played on element hover (use sparingly)
    Open    = 0,   -- played when the window is shown
}

local function PlaySound(id, vol, pitch)
    if not id or id == 0 then return end
    pcall(function()
        local s = Instance.new("Sound")
        s.SoundId          = "rbxassetid://" .. tostring(id)
        s.Volume           = vol   or 0.5
        s.PlaybackSpeed    = pitch or 1
        s.RollOffMaxDistance = 0
        s.Parent           = SoundService
        s:Play()
        Debris:AddItem(s, 3)
    end)
end

