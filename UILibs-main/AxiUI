            -- ──────────────────────────────────────────────────
            --  DEPENDS ON  (conditional visibility based on
            --               another Toggle or Option value)
            -- ──────────────────────────────────────────────────
            function go:SetDependency(controlObj, toggleIdx, predicate)
                -- controlObj: any widget returned by Add*
                -- toggleIdx: string key in Toggles table
                -- predicate: optional fn(value) → bool; defaults to truthiness
                local pred = predicate or function(v) return v == true end
                local function update()
                    local src = Toggles[toggleIdx]
                    if src then
                        controlObj:SetVisible(pred(src.Value))
                    end
                end
                update() -- apply immediately
                local src = Toggles[toggleIdx]
                if src and src.OnChanged then
                    src:OnChanged(function() update() end)
                end
            end

