function Library:_connect(sig, fn)
    local c = sig:Connect(fn)
    table.insert(self._connections, c)
    return c
end

function Library:Unload()
    if self.Unloaded then return end
    self.Unloaded = true
    for _, fn in ipairs(self._unloadFns) do pcall(fn) end
    for _, c  in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
    for _, w  in ipairs(self._windows) do pcall(function() w._sg:Destroy() end) end
    if self._notifSG then pcall(function() self._notifSG:Destroy() end) end
    if self._wmSG    then pcall(function() self._wmSG:Destroy() end) end
    if self._kbSG    then pcall(function() self._kbSG:Destroy() end) end
end

function Library:SetConfigFolder(name)
    self._configFolder = name
    pcall(function() if typeof(makefolder) == "function" and not isfolder(name) then makefolder(name) end end)
end

function Library:GetThemeNames()
    local n = {}
    for k in pairs(Themes) do table.insert(n, k) end
    return n
end

function Library:SetTheme(name)
    local t = Themes[name]
    if not t or self._themeSwitching then return end
    self._themeSwitching = true

    local function c2s(c) return math.floor(c.R*255+0.5)..","..math.floor(c.G*255+0.5)..","..math.floor(c.B*255+0.5) end
    local oldMap = {}
    for k, v in pairs(Theme) do oldMap[c2s(v)] = k end
    for k, v in pairs(t) do Theme[k] = v end

    local props = { "BackgroundColor3", "TextColor3", "ImageColor3" }
    local function repaintTree(root)
        local stack = { root }
        while #stack > 0 do
            local inst = stack[#stack]; stack[#stack] = nil
            pcall(function()
                for _, prop in ipairs(props) do
                    local ok, v = pcall(function() return inst[prop] end)
                    if ok and typeof(v) == "Color3" then
                        local key = oldMap[c2s(v)]
                        if key then pcall(function() inst[prop] = Theme[key] end) end
                    end
                end
                local sk = inst:FindFirstChildOfClass("UIStroke")
                if sk then
                    local ok, v = pcall(function() return sk.Color end)
                    if ok then local key = oldMap[c2s(v)]; if key then pcall(function() sk.Color = Theme[key] end) end end
                end
            end)
            for _, child in ipairs(inst:GetChildren()) do stack[#stack + 1] = child end
        end
    end

    for _, w in ipairs(self._windows) do pcall(function() repaintTree(w._sg) end) end
    if self._wmSG then pcall(function() repaintTree(self._wmSG) end) end
    if self._kbSG then pcall(function() repaintTree(self._kbSG) end) end
    if self._notifSG then pcall(function() repaintTree(self._notifSG) end) end

    if self._onThemeChanged then for _, fn in ipairs(self._onThemeChanged) do pcall(fn, name) end end
    self._themeSwitching = false
end

function Library:OnThemeChanged(fn)
    self._onThemeChanged = self._onThemeChanged or {}
    table.insert(self._onThemeChanged, fn)
end

