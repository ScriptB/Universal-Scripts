local function GetRoot()
    local ok, r = pcall(function()
        if typeof(gethui) == "function" then return gethui() end
        return CoreGui
    end)
    return ok and r or CoreGui
end

-- ── Config helpers (uses writefile / readfile if available) ───
local function SafeWrite(path, data)
    pcall(function()
        if typeof(writefile) == "function" then writefile(path, data) end
    end)
end
local function SafeRead(path)
    local ok, d = pcall(function()
        if typeof(readfile) == "function" then return readfile(path) end
        return nil
    end)
    return ok and d or nil
end
local function SafeJSON(t)
    local ok, s = pcall(function() return HttpService:JSONEncode(t) end)
    return ok and s or "{}"
end
local function SafeParse(s)
    local ok, t = pcall(function() return HttpService:JSONDecode(s) end)
    return ok and t or {}
end

