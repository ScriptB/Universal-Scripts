        LayoutOrder      = 0,
        Parent           = frame,
    })

    self._kbSG    = sg
    self._kbFrame = frame
    self._kbRows  = {}
end

function Library:_registerKeybind(idx, key, cb, mode)
    self:_buildKeybindOverlay()

    -- Set up the shared input listeners exactly once
    if not self._keybindListenersReady then
        self._keybindListenersReady = true
        self:_connect(UIS.InputBegan, function(i, gp)
            if gp then return end
            for _, kb in pairs(self._keybinds) do
                local match = (typeof(kb.key) == "EnumItem" and kb.key == i.KeyCode)
                           or (kb.key == i.UserInputType)
                if match then
                    if kb.mode == "Toggle" then
                        kb.enabled = not kb.enabled
                        pcall(kb.cb, kb.enabled)
                        if kb.overlayLabel then
                            kb.overlayLabel.TextColor3 = kb.enabled and Theme.AccentGlow or Theme.Accent
                        end
                    elseif kb.mode == "Hold" then
                        if not kb.enabled then
                            kb.enabled = true
                            pcall(kb.cb, true)
                            if kb.overlayLabel then kb.overlayLabel.TextColor3 = Theme.AccentGlow end
                        end
                    elseif kb.mode == "Always" then
                        pcall(kb.cb, true)
                    end
                end
            end
        end)
        self:_connect(UIS.InputEnded, function(i)
            for _, kb in pairs(self._keybinds) do
                if kb.mode == "Hold" then
                    local match = (typeof(kb.key) == "EnumItem" and kb.key == i.KeyCode)
                               or (kb.key == i.UserInputType)
                    if match and kb.enabled then
                        kb.enabled = false
                        pcall(kb.cb, false)
                        if kb.overlayLabel then kb.overlayLabel.TextColor3 = Theme.Accent end
                    end
                end
            end
        end)
    end

    local function keyDisplay(k)
        if not k then return "None" end
        if typeof(k) == "EnumItem" then return k.Name end
        return tostring(k)
    end

    -- Rebind path: update existing entry and overlay label only
    if self._keybinds[idx] then
        self._keybinds[idx].key  = key
        if cb   then self._keybinds[idx].cb   = cb   end
        if mode then self._keybinds[idx].mode = mode end
        if self._keybinds[idx].overlayLabel then
            self._keybinds[idx].overlayLabel.Text = "[" .. keyDisplay(key) .. "]"
        end
        return
    end

    -- First registration: create overlay row
    local row = New("Frame", {
        BackgroundTransparency = 1,
        Size             = UDim2.new(1, 0, 0, 16),
        Parent           = self._kbFrame,
    })
    New("TextLabel", {
        Text             = idx,
        Font             = Enum.Font.Gotham,
        TextSize         = 11,
        TextColor3       = Theme.SubText,
        TextXAlignment   = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Size             = UDim2.new(0.6, 0, 1, 0),
        Parent           = row,
    })
    local kl = New("TextLabel", {
        Text             = "[" .. keyDisplay(key) .. "]",
        Font             = Enum.Font.GothamBold,
        TextSize         = 11,
        TextColor3       = Theme.Accent,
        TextXAlignment   = Enum.TextXAlignment.Right,
        BackgroundTransparency = 1,
        Size             = UDim2.new(0.4, 0, 1, 0),
        Position         = UDim2.new(0.6, 0, 0, 0),
        Parent           = row,
    })
    table.insert(self._kbRows, row)

    self._keybinds[idx] = {
        key          = key,
        cb           = cb or function() end,
        mode         = mode or "Toggle",
        enabled      = false,
        overlayLabel = kl,
    }
end

function Library:SetKeybindOverlayVisible(v)
    self:_buildKeybindOverlay()
    self._kbSG.Enabled = v == true
end

-- ══════════════════════════════════════════════════════════════
--  PASS 2 — CreateWindow · Intro · TabBar · Groupbox
--           Toggle · Button (ripple, sub, double) · Slider
-- ══════════════════════════════════════════════════════════════

--[[
    UI:CreateWindow({
        Title       = "My Hub",
        SubTitle    = "v1.0",
        ToggleKey   = Enum.KeyCode.RightShift,
        Size        = UDim2.new(0, 600, 0, 420),
        Center      = true,
        AutoShow    = true,
        Intro       = true,          -- animated intro splash
        IntroText   = "Loading...",
        IntroIcon   = nil,           -- rbxassetid:// optional
        Icon        = nil,           -- rbxassetid:// title bar icon
        CloseCallback  = nil,
        MinimiseOnClose = false,     -- hide instead of destroy on X
    })
]]
function Library:CreateWindow(opts)
    opts = opts or {}
    local title     = opts.Title    or "AxiUI"
    local sub       = opts.SubTitle or ""
    local _tKey     = { v = opts.ToggleKey or Enum.KeyCode.RightShift }
    local winSize   = opts.Size     or UDim2.new(0, 600, 0, 420)
    local center    = opts.Center   ~= false
    local autoShow  = opts.AutoShow ~= false
    local doIntro   = opts.Intro    ~= false
    local introText = opts.IntroText or title
    local introIcon = opts.IntroIcon
    local winIcon   = opts.Icon
    local onClose   = opts.CloseCallback
    local minOnClose= opts.MinimiseOnClose or false
    local draggable = opts.Draggable ~= false
    local winPos    = opts.Position or (center and UDim2.new(0.5, 0, 0.5, 0) or UDim2.new(0, 60, 0, 60))

    -- For draggable windows, pre-resolve to pixel offsets + AnchorPoint(0,0)
    -- so the Draggable handler never has to normalise at runtime.
    local _initAnchor = center and Vector2.new(0.5, 0.5) or Vector2.new(0, 0)
    local _initPos    = winPos
    if draggable then
        local vp = (workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize)
                   or Vector2.new(1920, 1080)
        local pw = winSize.X.Scale * vp.X + winSize.X.Offset
        local ph = winSize.Y.Scale * vp.Y + winSize.Y.Offset
        local absX = winPos.X.Scale * vp.X + winPos.X.Offset - pw * _initAnchor.X
        local absY = winPos.Y.Scale * vp.Y + winPos.Y.Offset - ph * _initAnchor.Y
        _initAnchor = Vector2.new(0, 0)
        _initPos    = UDim2.new(0, math.floor(absX), 0, math.floor(absY))
    end

    -- ── ScreenGui ────────────────────────────────────────────
    local sg = New("ScreenGui", {
        Name           = "AxiUI_" .. title,
        ResetOnSpawn   = false,
        IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 100,
        Enabled        = autoShow,
        Parent         = GetRoot(),
    })

    -- ── Drop shadow (image-based) ────────────────────────────
    local shadowWrap = New("Frame", {
        BackgroundTransparency = 1,
        AnchorPoint  = _initAnchor,
        Position     = _initPos,
        Size         = winSize,
        Parent       = sg,
    })
    New("ImageLabel", {
        BackgroundTransparency = 1,
        Image             = "rbxassetid://6014261993",
        ImageColor3       = Theme.Black,
        ImageTransparency = 0.55,
        ScaleType         = Enum.ScaleType.Slice,
        SliceCenter       = Rect.new(49, 49, 450, 450),
        AnchorPoint       = Vector2.new(0.5, 0.5),
        Position          = UDim2.new(0.5, 0, 0.5, 6),
        Size              = UDim2.new(1, 48, 1, 48),
        ZIndex            = 0,
        Parent            = shadowWrap,
    })

    -- ── Main window frame ────────────────────────────────────
    local win = New("Frame", {
        Name             = "Window",
        BackgroundColor3 = Theme.Background,
        Size             = UDim2.new(1, 0, 1, 0),
        ClipsDescendants = false,   -- must be false: Roblox clips to rect, not UICorner
        Visible          = true,
        Parent           = shadowWrap,
    })
    Corner(win, 10)
    local winStroke = Stroke(win, Theme.Border, 1)

    -- Inner gradient, subtle depth — corner-rounded so it doesn't poke out of win
    local depthFrame = New("Frame", {
        BackgroundColor3       = Theme.PanelDeep,
        BackgroundTransparency = 0.7,
        Size                   = UDim2.new(1, 0, 0.5, 0),
        BorderSizePixel        = 0,
        ZIndex                 = 0,
        Parent                 = win,
    })
    Corner(depthFrame, 10)  -- matches win radius; bottom half covers bottom corners below centre

    -- ── Title Bar ────────────────────────────────────────────
    local titleBar = New("Frame", {
        Name             = "TitleBar",
        BackgroundColor3 = Theme.TitleLeft,
        Size             = UDim2.new(1, 0, 0, 42),
        BorderSizePixel  = 0,
        ZIndex           = 4,
        Parent           = win,
    })
    -- Round only the top corners of the title bar to match win's radius.
    -- Bottom corners are hidden behind tabBar/content, so rounding all 4 is fine.
    Corner(titleBar, 10)
    -- Gradient sits inside titleBar, fully covered by it — no extra UICorner needed
    local tbGrad = New("Frame", {
        BackgroundColor3       = Theme.TitleRight,
        BackgroundTransparency = 0,
        Size                   = UDim2.new(1, 0, 1, 0),
        BorderSizePixel        = 0,
        ZIndex                 = 2,
        Parent                 = titleBar,
    })
    Gradient(tbGrad, Theme.TitleLeft, Theme.TitleRight, 0)

    -- Accent line under title bar
    New("Frame", {
        BackgroundColor3 = Theme.Accent,
        BackgroundTransparency = 0.5,
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BorderSizePixel  = 0,
        ZIndex           = 5,
        Parent           = titleBar,
    })

    -- Optional icon
    local titleXOffset = 12
    if winIcon then
        New("ImageLabel", {
            Image            = winIcon,
            BackgroundTransparency = 1,
            Size             = UDim2.new(0, 22, 0, 22),
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(0, 12, 0.5, 0),
            ZIndex           = 6,
            Parent           = titleBar,
        })
        titleXOffset = 40
    end

    New("TextLabel", {
        Text             = title .. (sub ~= "" and ("  ·  " .. sub) or ""),
        Font             = Enum.Font.GothamBold,
        TextSize         = 14,
        TextColor3       = Theme.Text,
        TextXAlignment   = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, titleXOffset, 0, 0),
        Size             = UDim2.new(1, -(titleXOffset + 72), 1, 0),
        ZIndex           = 6,
        Parent           = titleBar,
    })

    -- Window controls (×  –)
    local function makeCtrlBtn(char, x)
        return New("TextButton", {
            Text             = char,
            Font             = Enum.Font.GothamBold,
            TextSize         = 16,
            TextColor3       = Theme.MutedText,
            BackgroundTransparency = 1,
            Size             = UDim2.new(0, 28, 0, 28),
            AnchorPoint      = Vector2.new(1, 0.5),
            Position         = UDim2.new(1, x, 0.5, 0),
            ZIndex           = 7,
            Parent           = titleBar,
        })
    end
    local closeBtn = makeCtrlBtn("×", -6)
    local minBtn   = makeCtrlBtn("–", -34)

    closeBtn.MouseEnter:Connect(function() Tween(closeBtn, { TextColor3 = Theme.Danger  }, 0.08) end)
    closeBtn.MouseLeave:Connect(function() Tween(closeBtn, { TextColor3 = Theme.MutedText }, 0.08) end)
    closeBtn.MouseButton1Click:Connect(function()
        if self.Unloaded then return end  -- guard double-click
        if onClose then
            local ok, result = pcall(onClose)
            if ok and result == false then return end   -- callback returned false → cancel close
        end
        self:Unload()
    end)

    -- Forward refs for tabBar + content — assigned when those frames are built below.
    -- Needed so the minimize closure (defined here) can reference them.
    local _tabBar, _content

    local minimised = false
    local collapsedH = 42
    minBtn.MouseEnter:Connect(function() Tween(minBtn, { TextColor3 = Theme.Gold }, 0.08) end)
    minBtn.MouseLeave:Connect(function() Tween(minBtn, { TextColor3 = Theme.MutedText }, 0.08) end)
    minBtn.MouseButton1Click:Connect(function()
        minimised = not minimised
        -- shadowWrap.AnchorPoint is (0,0) from creation (pre-resolved).
        -- Tweening Size with AnchorPoint (0,0) grows/shrinks downward only;
        -- the top-left corner (= title bar) never moves.
        if minimised then
            if _tabBar  then _tabBar.Visible  = false end
            if _content then _content.Visible = false end
            local w = shadowWrap.AbsoluteSize.X
            Tween(shadowWrap, { Size = UDim2.new(0, w, 0, collapsedH) }, 0.18, Enum.EasingStyle.Quart)
        else
            local w = winSize.X.Offset
            local h = winSize.Y.Offset
            Tween(shadowWrap, { Size = UDim2.new(0, w, 0, h) }, 0.2, Enum.EasingStyle.Quart)
            task.delay(0.2, function()
                if _tabBar  then _tabBar.Visible  = true end
                if _content then _content.Visible = true end
            end)
        end
    end)

    if draggable then
        Draggable(shadowWrap, titleBar)
    end

    -- ── Tab bar ──────────────────────────────────────────────
    local tabBar = New("Frame", {
        Name             = "TabBar",
        BackgroundColor3 = Theme.PanelDeep,
        BackgroundTransparency = 0,
        Size             = UDim2.new(1, 0, 0, 34),
        Position         = UDim2.new(0, 0, 0, 42),
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        ZIndex           = 3,
        Parent           = win,
    })
    _tabBar = tabBar   -- expose to minimize closure
    -- subtle separator under tabbar
    New("Frame", {
        BackgroundColor3 = Theme.Border,
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BorderSizePixel  = 0,
        ZIndex           = 4,
        Parent           = tabBar,
    })

    local tabScroll = New("ScrollingFrame", {
        BackgroundTransparency = 1,
        Size             = UDim2.new(1, 0, 1, 0),
        CanvasSize       = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.X,
        ScrollBarThickness = 0,
        ScrollingDirection = Enum.ScrollingDirection.X,
        BorderSizePixel  = 0,
        ZIndex           = 4,
        Parent           = tabBar,
    })
    List(tabScroll, 2, Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Center)
    Pad(tabScroll, 0, 0, 8, 8)

    -- ── Content area ─────────────────────────────────────────
    local content = New("Frame", {
        Name             = "Content",
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Position         = UDim2.new(0, 0, 0, 76),
        Size             = UDim2.new(1, 0, 1, -76),
        ZIndex           = 1,
        Parent           = win,
    })
    _content = content   -- expose to minimize closure

    -- ── Intro splash ─────────────────────────────────────────
    if doIntro then
        local splash = New("Frame", {
            BackgroundColor3 = Theme.Background,
            Size             = UDim2.new(1, 0, 1, 0),
            ZIndex           = 50,
            Parent           = win,
        })
        Corner(splash, 10)

        if introIcon then
            New("ImageLabel", {
                Image            = introIcon,
                BackgroundTransparency = 1,
                Size             = UDim2.new(0, 56, 0, 56),
                AnchorPoint      = Vector2.new(0.5, 0.5),
                Position         = UDim2.new(0.5, 0, 0.45, 0),
                ZIndex           = 51,
                Parent           = splash,
            })
        end
        local introLbl = New("TextLabel", {
            Text             = introText,
            Font             = Enum.Font.GothamBold,
            TextSize         = 18,
            TextColor3       = Theme.Text,
            BackgroundTransparency = 1,
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = introIcon and UDim2.new(0.5, 0, 0.58, 0) or UDim2.new(0.5, 0, 0.46, 0),
            Size             = UDim2.new(0.8, 0, 0, 24),
            ZIndex           = 51,
            Parent           = splash,
        })
        local introSub = New("TextLabel", {
            Text             = "by AxiUI  v" .. self._VERSION,
            Font             = Enum.Font.Gotham,
            TextSize         = 12,
            TextColor3       = Theme.MutedText,
            BackgroundTransparency = 1,
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(0.5, 0, introIcon and 0.65 or 0.54, 0),
            Size             = UDim2.new(0.8, 0, 0, 16),
            ZIndex           = 51,
            Parent           = splash,
        })
        -- loading bar
        local lbTrack = New("Frame", {
            BackgroundColor3 = Theme.Element,
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new(0.5, 0, introIcon and 0.74 or 0.62, 0),
            Size             = UDim2.new(0.55, 0, 0, 3),
            BorderSizePixel  = 0,
            ZIndex           = 51,
            Parent           = splash,
        })
        Corner(lbTrack, 2)
        local lbFill = New("Frame", {
            BackgroundColor3 = Theme.Accent,
            Size             = UDim2.new(0, 0, 1, 0),
            BorderSizePixel  = 0,
            ZIndex           = 52,
            Parent           = lbTrack,
        })
        Corner(lbFill, 2)

        -- Animate loading bar then fade out splash
        Tween(lbFill, { Size = UDim2.new(1, 0, 1, 0) }, 0.85, Enum.EasingStyle.Quart)
        task.delay(0.95, function()
            Tween(splash, { BackgroundTransparency = 1 }, 0.35, Enum.EasingStyle.Quad)
            Tween(introLbl, { TextTransparency = 1 }, 0.3)
            Tween(introSub,  { TextTransparency = 1 }, 0.3)
            Tween(lbTrack, { BackgroundTransparency = 1 }, 0.3)
            Tween(lbFill,  { BackgroundTransparency = 1 }, 0.3)
            task.delay(0.4, function() pcall(function() splash:Destroy() end) end)
        end)
    end

    -- ── Window Object ────────────────────────────────────────
    local Win      = {}
    Win.__index    = Win
    Win._sg        = sg
    Win._shadow    = shadowWrap
    Win._win       = win
    Win._content   = content
    Win._tabs      = {}
    Win._activeTab = nil
    Win._lib       = self

    -- Visibility: single-source-of-truth (_vis) + 150ms spam guard (_tLock)
    -- SetVisible(false): hides frame then disables ScreenGui input gate
    -- SetVisible(true):  re-enables ScreenGui then reveals frame
    -- When hidden: sg.Enabled=false → nothing inside receives any input,
    --   no MouseEnter, no focus, no layout recalculation — perfectly frozen.
    local _vis   = autoShow
    local _tLock = false
    function Win:SetVisible(v)
        _vis = v
        if v then
            sg.Enabled         = true
            shadowWrap.Visible = true
            -- Accent–border flash: tells the user the UI snapped back into place
            Tween(winStroke, { Color = Theme.Accent }, 0)
            task.delay(0.08, function()
                if _vis then Tween(winStroke, { Color = Theme.Border }, 0.5) end
            end)
            PlaySound(_sounds.Open, 0.4, 1.02)
        else
            shadowWrap.Visible = false
            sg.Enabled         = false
        end
    end
    function Win:Show()   self:SetVisible(true)  end
    function Win:Hide()   self:SetVisible(false) end
    function Win:Toggle()
        if Library.Unloaded then return end
        if _tLock then return end
        _tLock = true
        self:SetVisible(not _vis)
        task.delay(0.15, function() _tLock = false end)
    end
    -- Allow external code (e.g. rebind picker) to change which key fires Toggle.
    function Win:SetToggleKey(k) if k then _tKey.v = k end end
    -- Wire the toggle key — intentionally ignores gameProcessedEvent so the
    -- menu can be dismissed even when a widget inside it has focus.
    self:_connect(UIS.InputBegan, function(i)
        if i.KeyCode == _tKey.v then Win:Toggle() end
    end)

    -- ── AddTab ───────────────────────────────────────────────
    function Win:AddTab(name, icon)
        local tab      = {}
        tab._name      = name
        tab._win       = self
        tab._elements  = {}

        -- Tab button
        local tBtn = New("TextButton", {
            Text             = icon and "" or name,
            Font             = Enum.Font.Gotham,
            TextSize         = 12,
            TextColor3       = Theme.MutedText,
            BackgroundColor3 = Theme.PanelDeep,
            BackgroundTransparency = 1,
            AutomaticSize    = Enum.AutomaticSize.X,
            Size             = UDim2.new(0, 0, 1, -6),
            AnchorPoint      = Vector2.new(0, 0.5),
            BorderSizePixel  = 0,
            Parent           = tabScroll,
        })
        Corner(tBtn, 5)
        Pad(tBtn, 0, 0, 12, 12)

        if icon then
            New("ImageLabel", {
                Image            = icon,
                BackgroundTransparency = 1,
                Size             = UDim2.new(0, 16, 0, 16),
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, 8, 0.5, 0),
                ZIndex           = 3,
                Parent           = tBtn,
            })
            New("TextLabel", {
                Text             = name,
                Font             = Enum.Font.Gotham,
                TextSize         = 12,
                TextColor3       = Theme.MutedText,
                BackgroundTransparency = 1,
                Position         = UDim2.new(0, 28, 0, 0),
                Size             = UDim2.new(1, -28, 1, 0),
                ZIndex           = 3,
                Parent           = tBtn,
            })
            tab._tBtnLabel = tBtn:FindFirstChildOfClass("TextLabel")
        else
            tab._tBtnLabel = tBtn
        end

        -- Active indicator bar
        local tInd = New("Frame", {
            BackgroundColor3 = Theme.Accent,
            Size             = UDim2.new(0, 0, 0, 2),
            Position         = UDim2.new(0.5, 0, 1, 0),
            AnchorPoint      = Vector2.new(0.5, 1),
            BorderSizePixel  = 0,
            ZIndex           = 3,
            Parent           = tBtn,
        })
        Corner(tInd, 1)
        tab._tInd = tInd

        -- Page frame
        local page = New("Frame", {
            BackgroundTransparency = 1,
            Size             = UDim2.new(1, 0, 1, 0),
            Visible          = false,
            Parent           = content,
        })
        Pad(page, 8, 8, 8, 8)
        tab._page = page

        -- Two scrolling columns
        local function makeCol(xPos, xSize)
            local sc = New("ScrollingFrame", {
                BackgroundTransparency = 1,
                ScrollBarThickness     = 3,
                ScrollBarImageColor3   = Theme.Border,
                ScrollingDirection     = Enum.ScrollingDirection.Y,
                CanvasSize             = UDim2.new(0, 0, 0, 0),
                AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                Size                   = UDim2.new(xSize, -4, 1, -2),
                Position               = UDim2.new(xPos,  xPos == 0 and 0 or 4, 0, 0),
                BorderSizePixel        = 0,
                Parent                 = page,
            })
            List(sc, 6)
            return sc
        end
        tab._leftCol  = makeCol(0, 0.5)
        tab._rightCol = makeCol(0.5, 0.5)
        -- single-column alias
        tab._fullCol  = tab._leftCol

        -- Activate first tab
        local isFirst = #self._tabs == 0
        if isFirst then
            page.Visible = true
            Tween(tBtn, { TextColor3 = Theme.Accent, BackgroundTransparency = 0 }, 0)
            if tab._tBtnLabel then tab._tBtnLabel.TextColor3 = Theme.Accent end
            Tween(tInd, { Size = UDim2.new(1, 0, 0, 2) }, 0)
            self._activeTab = tab
        end

        tBtn.MouseButton1Click:Connect(function()
            if self._activeTab and self._activeTab ~= tab then
                local at = self._activeTab
                at._page.Visible = false
                Tween(at._tBtn, { TextColor3 = Theme.MutedText, BackgroundTransparency = 1 }, 0.1)
                if at._tBtnLabel then Tween(at._tBtnLabel, { TextColor3 = Theme.MutedText }, 0.1) end
                Tween(at._tInd, { Size = UDim2.new(0, 0, 0, 2) }, 0.1)
            end
            tab._page.Visible = true
            self._activeTab = tab
            Tween(tBtn, { TextColor3 = Theme.Accent, BackgroundTransparency = 0 }, 0.12)
            if tab._tBtnLabel then Tween(tab._tBtnLabel, { TextColor3 = Theme.Accent }, 0.12) end
            Tween(tInd, { Size = UDim2.new(1, 0, 0, 2) }, 0.14, Enum.EasingStyle.Back)
        end)
        tBtn.MouseEnter:Connect(function()
            if self._activeTab ~= tab then
                Tween(tBtn, { TextColor3 = Theme.SubText }, 0.08)
                if tab._tBtnLabel then Tween(tab._tBtnLabel, { TextColor3 = Theme.SubText }, 0.08) end
            end
        end)
        tBtn.MouseLeave:Connect(function()
            if self._activeTab ~= tab then
                Tween(tBtn, { TextColor3 = Theme.MutedText }, 0.08)
                if tab._tBtnLabel then Tween(tab._tBtnLabel, { TextColor3 = Theme.MutedText }, 0.08) end
            end
        end)

        tab._tBtn = tBtn
        table.insert(self._tabs, tab)

        -- ── Groupbox factory ──────────────────────────────────
        local function _newGroupbox(gbName, parent)
            local go = {}
            go.__index = go

            local wrap = New("Frame", {
                BackgroundColor3 = Theme.Panel,
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BorderSizePixel  = 0,
                Parent           = parent,
            })
            Corner(wrap, 8)
            Stroke(wrap, Theme.Border, 1)

            -- Header
            local hdr = New("Frame", {
                Name             = "GBHeader",
                BackgroundColor3 = Theme.PanelAlt,
                Size             = UDim2.new(1, 0, 0, 30),
                BorderSizePixel  = 0,
                ZIndex           = 2,
                Parent           = wrap,
            })
            New("UICorner", { CornerRadius = UDim.new(0, 8), Parent = hdr })
            -- Square off bottom corners of header
            New("Frame", {
                BackgroundColor3 = Theme.PanelAlt,
                Size             = UDim2.new(1, 0, 0.5, 0),
                Position         = UDim2.new(0, 0, 0.5, 0),
                BorderSizePixel  = 0,
                Parent           = hdr,
            })
            -- Accent left stripe
            local hdrStripe = New("Frame", {
                BackgroundColor3 = Theme.Accent,
                Size             = UDim2.new(0, 3, 0.55, 0),
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, 0, 0.5, 0),
                BorderSizePixel  = 0,
                ZIndex           = 3,
                Parent           = hdr,
            })
            Corner(hdrStripe, 2)
            New("TextLabel", {
                Text             = gbName,
                Font             = Enum.Font.GothamBold,
                TextSize         = 11,
                TextColor3       = Theme.SubText,
                TextXAlignment   = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Position         = UDim2.new(0, 14, 0, 0),
                Size             = UDim2.new(1, -18, 1, 0),
                ZIndex           = 3,
                Parent           = hdr,
            })

            -- Body
            local body = New("Frame", {
                BackgroundTransparency = 1,
                Position         = UDim2.new(0, 0, 0, 30),
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                Parent           = wrap,
            })
            Pad(body, 6, 8, 8, 8)
            List(body, 5)

            go._wrap = wrap
            go._body = body

            -- Common element lifecycle API used by controls.
            local function _attachElementAPI(obj, container, setTextFn)
                obj._container = container
                function obj:SetVisible(v)
                    if container then container.Visible = v ~= false end
                    return self
                end
                function obj:Show()
                    return self:SetVisible(true)
                end
                function obj:Hide()
                    return self:SetVisible(false)
                end
                function obj:SetText(t)
                    if setTextFn then pcall(setTextFn, tostring(t or "")) end
                    return self
                end
                function obj:Remove()
                    if container then
                        pcall(function() container:Destroy() end)
                        container = nil
                        self._container = nil
                    end
                end
                return obj
            end

            -- Tooltip helper: shows a floating popup near a "?" icon
            local function _attachTooltip(parent, tipText, xOffset)
                if not tipText then return end
                xOffset = xOffset or -52
                local tip = New("TextLabel", {
                    Text             = " ? ",
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 9,
                    TextColor3       = Theme.MutedText,
                    BackgroundColor3 = Theme.PanelAlt,
                    Size             = UDim2.new(0, 16, 0, 16),
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, xOffset, 0.5, 0),
                    ZIndex           = 3,
                    Parent           = parent,
                })
                Corner(tip, 4)
                local popup
                tip.MouseEnter:Connect(function()
                    local _tx = tip.AbsolutePosition.X - 72
                    local _ty = tip.AbsolutePosition.Y - 36
                    popup = New("TextLabel", {
                        Text                   = tipText,
                        Font                   = Enum.Font.Gotham,
                        TextSize               = 11,
                        TextColor3             = Theme.Text,
                        BackgroundColor3       = Theme.PanelAlt,
                        BackgroundTransparency = 0,
                        TextWrapped            = true,
                        Size                   = UDim2.new(0, 160, 0, 0),
                        AutomaticSize          = Enum.AutomaticSize.Y,
                        Position               = UDim2.new(0, _tx, 0, _ty),
                        ZIndex                 = 20,
                        Parent                 = sg,
                    })
                    Corner(popup, 5)
                    Stroke(popup, Theme.Border)
                    Pad(popup, 5, 5, 8, 8)
                end)
                tip.MouseLeave:Connect(function()
                    if popup then popup:Destroy(); popup = nil end
                end)
            end

            -- ──────────────────────────────────────────────────
            --  TOGGLE (Modular, Documented, Icon-ready)
            -- ──────────────────────────────────────────────────
            ---
            -- Adds a toggle switch to the groupbox.
            -- @param idx (string) Unique identifier
            -- @param opts (table) Options: Text, Default, Tooltip, Callback, Icon
            -- @return Toggle object with SetValue, OnChanged, GetValue, SetCallback
            function go:AddToggle(idx, opts)
                opts = opts or {}
                local text    = opts.Text    or idx
                local default = opts.Default ~= nil and opts.Default or false
                local tooltip = opts.Tooltip
                local cb      = opts.Callback or function() end
                local icon    = opts.Icon     -- (optional) icon name from icon library

                local obj = { Value = default, _cbs = {} }
                Toggles[idx] = obj

                local row = New("TextButton", {
                    Text             = "",
                    BackgroundColor3 = Theme.Element,
                    Size             = UDim2.new(1, 0, 0, 30),
                    BorderSizePixel  = 0,
                    ClipsDescendants = true,
                    Parent           = body,
                })
                Corner(row, 6)

                -- Optional icon (placeholder for icon library integration)
                if icon then
                    -- TODO: Integrate icon library lookup here
                    New("ImageLabel", {
                        Image = "rbxassetid://ICON_ASSET_ID", -- Replace with icon lookup
                        BackgroundTransparency = 1,
                        Size = UDim2.new(0, 18, 0, 18),
                        Position = UDim2.new(0, 6, 0.5, -9),
                        ZIndex = 3,
                        Parent = row,
                    })
                end

                -- label
                New("TextLabel", {
                    Text             = text,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Position         = UDim2.new(0, icon and 28 or 10, 0, 0),
                    Size             = UDim2.new(1, -58, 1, 0),
                    ZIndex           = 2,
                    Parent           = row,
                })

                -- pill track
                local track = New("Frame", {
                    BackgroundColor3 = default and Theme.ToggleOn or Theme.ToggleOff,
                    Size             = UDim2.new(0, 36, 0, 18),
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, -10, 0.5, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = 2,
                    Parent           = row,
                })
                Corner(track, 9)
                Stroke(track, default and Theme.AccentDim or Theme.Border, 1)

                -- knob with glow
                local knob = New("Frame", {
                    BackgroundColor3 = default and Theme.AccentGlow or Theme.SubText,
                    Size             = UDim2.new(0, 13, 0, 13),
                    AnchorPoint      = Vector2.new(0, 0.5),
                    Position         = default and UDim2.new(0, 21, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = 3,
                    Parent           = track,
                })
                Corner(knob, 7)

                -- tooltip
                _attachTooltip(row, tooltip)

                local function setVisual(v)
                    Tween(track, { BackgroundColor3 = v and Theme.ToggleOn or Theme.ToggleOff }, 0.14)
                    Tween(knob,  {
                        BackgroundColor3 = v and Theme.AccentGlow or Theme.SubText,
                        Position         = v and UDim2.new(0, 21, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
                    }, 0.14, Enum.EasingStyle.Back)
                    -- update stroke colour
                    local sk = track:FindFirstChildOfClass("UIStroke")
                    if sk then Tween(sk, { Color = v and Theme.AccentDim or Theme.Border }, 0.14) end
                end

                row.MouseButton1Click:Connect(function()
                    -- ripple
                    local mx = UIS:GetMouseLocation().X - row.AbsolutePosition.X
                    local my = UIS:GetMouseLocation().Y - row.AbsolutePosition.Y
                    MakeRipple(row, mx, my, Theme.Accent)
                    PlaySound(_sounds.Toggle, 0.4, obj.Value and 0.92 or 1.08)
                    obj.Value = not obj.Value
                    setVisual(obj.Value)
                    _fire(cb, obj._cbs, obj.Value)
                end)
                _attachHover(row)

                function obj:SetValue(v)
                    self.Value = v; setVisual(v)
                    _fire(cb, self._cbs, v)
                end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:GetValue()    return self.Value end
                function obj:SetCallback(fn) cb = fn end
                _attachElementAPI(obj, row)
                return obj
            end

            -- ──────────────────────────────────────────────────
            --  BUTTON  (ripple · sub-button · double-click)
            -- ──────────────────────────────────────────────────
            function go:AddButton(opts)
                if type(opts) == "string" then opts = { Text = opts } end
                opts = opts or {}
                local text   = opts.Text        or "Button"
                local func   = opts.Func or opts.Callback or function() end
                local dbl    = opts.DoubleClick or false
                local tip    = opts.Tooltip
                local color  = opts.Color       -- optional accent colour

                local obj       = {}
                local lastClick = 0

                local btn = New("TextButton", {
                    Text             = text,
                    Font             = Enum.Font.GothamSemibold,
                    TextSize         = 12,
                    TextColor3       = color or Theme.Text,
                    BackgroundColor3 = Theme.Element,
                    Size             = UDim2.new(1, 0, 0, 30),
                    BorderSizePixel  = 0,
                    ClipsDescendants = true,
                    Parent           = body,
                })
                Corner(btn, 6)
                if color then Stroke(btn, color, 1, 0.6) end

                _attachHover(btn)
                _attachTooltip(btn, tip, -6)

                btn.MouseButton1Click:Connect(function()
                    local mx = UIS:GetMouseLocation().X - btn.AbsolutePosition.X
                    local my = UIS:GetMouseLocation().Y - btn.AbsolutePosition.Y
                    MakeRipple(btn, mx, my, color or Theme.Accent)
                    PlaySound(_sounds.Click, 0.35, 1.0)
                    if dbl then
                        local now = tick()
                        if now - lastClick < 0.38 then
                            pcall(func); lastClick = 0
                        else
                            lastClick = now
                            Tween(btn, { BackgroundColor3 = Theme.ElementAct }, 0.08)
                            task.delay(0.15, function() Tween(btn, { BackgroundColor3 = Theme.Element }, 0.1) end)
                        end
                    else
                        pcall(func)
                    end
                end)

                -- sub-button
                function obj:AddButton(sOpts)
                    if type(sOpts) == "string" then sOpts = { Text = sOpts } end
                    sOpts = sOpts or {}
                    local sb = New("TextButton", {
                        Text             = "  ↳  " .. (sOpts.Text or "Sub"),
                        Font             = Enum.Font.Gotham,
                        TextSize         = 11,
                        TextColor3       = Theme.SubText,
                        TextXAlignment   = Enum.TextXAlignment.Left,
                        BackgroundColor3 = Theme.PanelAlt,
                        Size             = UDim2.new(1, 0, 0, 24),
                        BorderSizePixel  = 0,
                        ClipsDescendants = true,
                        Parent           = body,
                    })
                    Corner(sb, 5)
                    local sf = sOpts.Func or sOpts.Callback or function() end
                    sb.MouseEnter:Connect(function() Tween(sb, { BackgroundColor3 = Theme.Element }, 0.08) end)
                    sb.MouseLeave:Connect(function() Tween(sb, { BackgroundColor3 = Theme.PanelAlt }, 0.08) end)
                    sb.MouseButton1Click:Connect(function()
                        MakeRipple(sb, UIS:GetMouseLocation().X - sb.AbsolutePosition.X,
                            UIS:GetMouseLocation().Y - sb.AbsolutePosition.Y, Theme.Accent)
                        pcall(sf)
                    end)
                    local sObj = {}
                    function sObj:AddButton(o) return obj:AddButton(o) end
                    return sObj
                end

                function obj:SetCallback(fn) func = fn end
                _attachElementAPI(obj, btn, function(t) btn.Text = t end)
                return obj
            end

            -- ──────────────────────────────────────────────────
            --  SLIDER  (precise · suffix · rounding · step)
            -- ──────────────────────────────────────────────────
            function go:AddSlider(idx, opts)
                opts = opts or {}
                local text    = opts.Text     or idx
                local min_    = opts.Min      or 0
                local max_    = opts.Max      or 100
                local default = opts.Default  ~= nil and opts.Default or min_
                local rounding= opts.Rounding or 0
                local suffix  = opts.Suffix   or ""
                local step    = opts.Step     -- optional snap-to step
                local tooltip = opts.Tooltip
                local cb      = opts.Callback or function() end

                local obj = { Value = Round(default, rounding), _cbs = {} }
                Options[idx] = obj

                local function snap(v)
                    if step then
                        v = Round(math.floor((v - min_) / step + 0.5) * step + min_, rounding)
                    else
                        v = Round(v, rounding)
                    end
                    return Clamp(v, min_, max_)
                end

                local wrap = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 46),
                    Parent           = body,
                })
                _attachTooltip(wrap, tooltip, -6)

                -- top row: label + value
                local topRow = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 18),
                    Parent           = wrap,
                })
                New("TextLabel", {
                    Text             = text,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, -70, 1, 0),
                    Parent           = topRow,
                })
                local valBox = New("TextBox", {
                    Text             = tostring(obj.Value) .. suffix,
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 12,
                    TextColor3       = Theme.Accent,
                    TextXAlignment   = Enum.TextXAlignment.Right,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(0, 66, 1, 0),
                    Position         = UDim2.new(1, -66, 0, 0),
                    BorderSizePixel  = 0,
                    ClearTextOnFocus = true,
                    Parent           = topRow,
                })
                -- type-in support
                valBox.FocusLost:Connect(function()
                    local raw = valBox.Text:gsub("[^%d%.%-]", "")
                    local num = tonumber(raw)
                    if num then
                        obj:SetValue(num)
                    else
                        valBox.Text = tostring(obj.Value) .. suffix
                    end
                end)

                -- track + fill + knob
                local track = New("Frame", {
                    BackgroundColor3 = Theme.SliderTrack,
                    Size             = UDim2.new(1, 0, 0, 8),
                    Position         = UDim2.new(0, 0, 0, 26),
                    BorderSizePixel  = 0,
                    Parent           = wrap,
                })
                Corner(track, 4)
                Stroke(track, Theme.Border, 1)

                local rel0 = (default - min_) / (max_ - min_)
                local fill = New("Frame", {
                    BackgroundColor3 = Theme.SliderFill,
                    Size             = UDim2.new(rel0, 0, 1, 0),
                    BorderSizePixel  = 0,
                    Parent           = track,
                })
                Corner(fill, 4)
                -- fill gradient
                Gradient(fill, Theme.AccentDim, Theme.AccentGlow, 0)

                local knob = New("Frame", {
                    BackgroundColor3 = Theme.SliderKnob,
                    Size             = UDim2.new(0, 16, 0, 16),
                    AnchorPoint      = Vector2.new(0.5, 0.5),
                    Position         = UDim2.new(rel0, 0, 0.5, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = 3,
                    Parent           = track,
                })
                Corner(knob, 8)
                Stroke(knob, Theme.Border, 1)

                local function setFromRel(rel)
                    rel = Clamp(rel, 0, 1)
                    local v = snap(min_ + rel * (max_ - min_))
                    local r = (v - min_) / (max_ - min_)
                    obj.Value = v
                    Tween(fill,  { Size = UDim2.new(r, 0, 1, 0) }, 0.04)
                    Tween(knob,  { Position = UDim2.new(r, 0, 0.5, 0) }, 0.04)
                    valBox.Text = tostring(v) .. suffix
                    _fire(cb, obj._cbs, v)
                end

                local dragging = false
                track.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        setFromRel((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                    end
                end)
                Library:_connect(UIS.InputEnded, function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                Library:_connect(UIS.InputChanged, function(i)
                    if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                        setFromRel((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
                    end
                end)
                -- scroll wheel on track
                track.InputChanged:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseWheel then
                        local delta = i.Position.Z > 0 and 0.02 or -0.02
                        local curRel = (obj.Value - min_) / (max_ - min_)
                        setFromRel(curRel + delta)
                    end
                end)

                function obj:SetValue(v)
                    local r = (snap(v) - min_) / (max_ - min_)
                    self.Value = snap(v)
                    Tween(fill,  { Size = UDim2.new(r, 0, 1, 0) }, 0.1)
                    Tween(knob,  { Position = UDim2.new(r, 0, 0.5, 0) }, 0.1)
                    valBox.Text = tostring(self.Value) .. suffix
                    _fire(cb, self._cbs, self.Value)
                end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:GetValue()    return self.Value end
                function obj:SetCallback(fn) cb = fn end
                _attachElementAPI(obj, wrap)
                return obj
            end

            -- ──────────────────────────────────────────────────
            --  INPUT  (text / numeric · Finished · Max / PlaceholderText)
            -- ──────────────────────────────────────────────────
            function go:AddInput(idx, opts)
                opts = opts or {}
                local text      = opts.Text        or idx
                local numeric   = opts.Numeric     or false
                local finished  = opts.Finished    or false -- only fire on Enter
                local ph        = opts.PlaceholderText or (numeric and "0" or "...")
                local max_      = opts.MaxLength
                local tooltip   = opts.Tooltip
                local cb        = opts.Callback    or function() end
                local def       = opts.Default     or ""

                local obj = { Value = def, _cbs = {} }
                Options[idx] = obj

                local wrap = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 50),
                    Parent           = body,
                })
                _attachTooltip(wrap, tooltip, -6)
                New("TextLabel", {
                    Text             = text,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 18),
                    Parent           = wrap,
                })
                local box = New("TextBox", {
                    Text             = def,
                    PlaceholderText  = ph,
                    PlaceholderColor3= Theme.MutedText,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundColor3 = Theme.Element,
                    Size             = UDim2.new(1, 0, 0, 28),
                    Position         = UDim2.new(0, 0, 0, 20),
                    BorderSizePixel  = 0,
                    ClearTextOnFocus = false,
                    Parent           = wrap,
                })
                Corner(box, 5)
                Pad(box, 0, 0, 8, 8)
                local bStroke = Stroke(box, Theme.Border, 1)

                if numeric then
                    box:GetPropertyChangedSignal("Text"):Connect(function()
                        local cleaned = box.Text:gsub("[^%d%.%-]","")
                        if box.Text ~= cleaned then box.Text = cleaned end
                    end)
                end
                if max_ then
                    box:GetPropertyChangedSignal("Text"):Connect(function()
                        if #box.Text > max_ then
                            box.Text = box.Text:sub(1, max_)
                        end
                    end)
                end

                box.Focused:Connect(function()
                    Tween(bStroke, { Color = Theme.Accent }, 0.1)
                end)
                box.FocusLost:Connect(function(enter)
                    Tween(bStroke, { Color = Theme.Border }, 0.1)
                    local v = box.Text
                    if numeric then v = tonumber(v) or obj.Value end
                    if not finished or enter then
                        obj.Value = v; _fire(cb, obj._cbs, v)
                    end
                end)

                function obj:SetValue(v)
                    self.Value = v; box.Text = tostring(v)
                    _fire(cb, self._cbs, v)
                end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:GetValue()    return self.Value end
                function obj:SetCallback(fn) cb = fn end
                _attachElementAPI(obj, wrap)
                return obj
            end

            -- ──────────────────────────────────────────────────
            --  DROPDOWN  (single · multi · searchable · AddValue/RemoveValue/SetValues)
            -- ──────────────────────────────────────────────────
            function go:AddDropdown(idx, opts)
                opts = opts or {}
                local text   = opts.Text    or idx
                local vals   = opts.Values  or {}
                local def    = opts.Default
                local multi  = opts.Multi   or false
                local search = opts.AllowSearch ~= false
                local tooltip = opts.Tooltip
                local cb     = opts.Callback or function() end

                local obj  = { Value = multi and {} or def, _cbs = {}, _items = {} }
                Options[idx] = obj

                -- copy initial values
                for _, v in ipairs(vals) do obj._items[#obj._items+1] = v end
                if multi and def then
                    if type(def) == "table" then obj.Value = def
                    else obj.Value = {def} end
                end

                local wrap = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 0),
                    AutomaticSize    = Enum.AutomaticSize.Y,
                    ClipsDescendants = false,
                    Parent           = body,
                })
                _attachTooltip(wrap, tooltip, -6)
                New("TextLabel", {
                    Text             = text,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 18),
                    Parent           = wrap,
                })

                local function getDisplayText()
                    if multi then
                        if #obj.Value == 0 then return "None" end
                        return table.concat(obj.Value, ", ")
                    else
                        return obj.Value ~= nil and tostring(obj.Value) or "Select..."
                    end
                end

                local btn = New("TextButton", {
                    Text             = getDisplayText(),
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundColor3 = Theme.Element,
                    Size             = UDim2.new(1, 0, 0, 28),
                    Position         = UDim2.new(0, 0, 0, 20),
                    BorderSizePixel  = 0,
                    ClipsDescendants = false,
                    Parent           = wrap,
                })
                Corner(btn, 5)
                Pad(btn, 0, 0, 8, 8)
                -- arrow icon
                local arrow = New("TextLabel", {
                    Text             = "▾",
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 14,
                    TextColor3       = Theme.MutedText,
                    BackgroundTransparency = 1,
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, -8, 0.5, 0),
                    Size             = UDim2.new(0, 16, 0, 16),
                    Parent           = btn,
                })

                -- dropdown popup
                local popup     = nil
                local isOpen    = false
                local _ddOutsideConn = nil

                local function closePopup()
                    if _ddOutsideConn then _ddOutsideConn:Disconnect(); _ddOutsideConn = nil end
                    if popup then
                        -- Collapse to 0 height (ClipsDescendants hides items as it shrinks)
                        Tween(popup, { Size = UDim2.new(0, popup.AbsoluteSize.X, 0, 0) }, 0.11, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
                        Tween(arrow, { Rotation = 0 }, 0.11)
                        task.delay(0.12, function() pcall(function() if popup then popup:Destroy(); popup = nil end end) end)
                        isOpen = false
                    end
                end

                local function buildPopup()
                    if popup then popup:Destroy(); popup = nil end
                    local maxH = 160
                    -- Parent to sg so the ScrollingFrame column cannot clip the popup
                    local _bx = btn.AbsolutePosition.X
                    local _by = btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 3
                    local _bw = btn.AbsoluteSize.X
                    popup = New("Frame", {
                        BackgroundColor3 = Theme.PanelAlt,
                        BackgroundTransparency = 0,
                        BorderSizePixel  = 0,
                        Position         = UDim2.new(0, _bx, 0, _by),
                        Size             = UDim2.new(0, _bw, 0, 0),
                        ZIndex           = 10,
                        ClipsDescendants = true,
                        Parent           = sg,
                    })
                    Corner(popup, 6)
                    Stroke(popup, Theme.Border)

                    local yOff = 0

                    if search then
                        local sBox = New("TextBox", {
                            Text             = "",
                            PlaceholderText  = "Search...",
                            PlaceholderColor3= Theme.MutedText,
                            Font             = Enum.Font.Gotham,
                            TextSize         = 11,
                            TextColor3       = Theme.Text,
                            TextXAlignment   = Enum.TextXAlignment.Left,
                            BackgroundColor3 = Theme.Element,
                            Size             = UDim2.new(1, 0, 0, 24),
                            BorderSizePixel  = 0,
                            ZIndex           = 16,
                            ClearTextOnFocus = false,
                            Parent           = popup,
                        })
                        Corner(sBox, 5)
                        Pad(sBox, 0, 0, 6, 6)
                        yOff = 26
                        -- filter logic handled below
                        sBox:GetPropertyChangedSignal("Text"):Connect(function()
                            local q = sBox.Text:lower()
                            for _, child in ipairs(popup:GetChildren()) do
                                if child:IsA("TextButton") then
                                    child.Visible = q == "" or child.Text:lower():find(q, 1, true) ~= nil
                                end
                            end
                        end)
                    end

                    local sc = New("ScrollingFrame", {
                        BackgroundTransparency = 1,
                        ScrollBarThickness     = 3,
                        ScrollBarImageColor3   = Theme.Border,
                        CanvasSize             = UDim2.new(0,0,0,0),
                        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
                        Size                   = UDim2.new(1, 0, 1, -yOff),
                        Position               = UDim2.new(0, 0, 0, yOff),
                        BorderSizePixel        = 0,
                        ZIndex                 = 16,
                        Parent                 = popup,
                    })
                    List(sc, 1)
                    Pad(sc, 2, 2, 4, 4)

                    local function isSelected(v)
                        if multi then
                            for _, s in ipairs(obj.Value) do if s == v then return true end end
                            return false
                        else
                            return obj.Value == v
                        end
                    end

                    local itemBtns = {}
                    local function buildItems()
                        for _, ib in ipairs(itemBtns) do ib:Destroy() end
                        itemBtns = {}
                        for _, v in ipairs(obj._items) do
                            local ib = New("TextButton", {
                                Text             = (isSelected(v) and "✓  " or "    ") .. tostring(v),
                                Font             = Enum.Font.Gotham,
                                TextSize         = 12,
                                TextColor3       = isSelected(v) and Theme.Accent or Theme.Text,
                                TextXAlignment   = Enum.TextXAlignment.Left,
                                BackgroundColor3 = isSelected(v) and Theme.ElementAct or Theme.PanelAlt,
                                Size             = UDim2.new(1, 0, 0, 26),
                                BorderSizePixel  = 0,
                                ZIndex           = 17,
                                Parent           = sc,
                            })
                            Corner(ib, 4)
                            ib.MouseEnter:Connect(function() Tween(ib, { BackgroundColor3 = Theme.ElementHov }, 0.07) end)
                            ib.MouseLeave:Connect(function()
                                Tween(ib, { BackgroundColor3 = isSelected(v) and Theme.ElementAct or Theme.PanelAlt }, 0.07)
                            end)
                            ib.MouseButton1Click:Connect(function()
                                if multi then
                                    local found = false
                                    for i, s in ipairs(obj.Value) do
                                        if s == v then table.remove(obj.Value, i); found = true; break end
                                    end
                                    if not found then table.insert(obj.Value, v) end
                                else
                                    obj.Value = v
                                    closePopup()
                                end
                                btn.Text = getDisplayText()
                                _fire(cb, obj._cbs, obj.Value)
                                if multi then buildItems() end
                            end)
                            table.insert(itemBtns, ib)
                        end
                    end
                    buildItems()

                    local rows = math.min(#obj._items, 6)
                    local totalH = yOff + rows * 27 + 6
                    local finalH = math.max(40, totalH)
                    -- animate open: grow from 0 to full height (ClipsDescendants hides overflow)
                    Tween(popup, { Size = UDim2.new(0, _bw, 0, finalH) }, 0.14, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
                end

                btn.MouseButton1Click:Connect(function()
                    if isOpen then closePopup()
                    else
                        isOpen = true
                        buildPopup()
                        Tween(arrow, { Rotation = 180 }, 0.14)
                        -- Close when user clicks outside the dropdown popup
                        _ddOutsideConn = UIS.InputBegan:Connect(function(i, gp)
                            if gp then return end
                            if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                            if not popup then
                                if _ddOutsideConn then _ddOutsideConn:Disconnect(); _ddOutsideConn = nil end
                                return
                            end
                            local mx, my = i.Position.X, i.Position.Y
                            -- Skip if click is on the toggle button itself
                            local bx, by = btn.AbsolutePosition.X, btn.AbsolutePosition.Y
                            local bw, bh = btn.AbsoluteSize.X, btn.AbsoluteSize.Y
                            if mx >= bx and mx <= bx + bw and my >= by and my <= by + bh then return end
                            -- Close if click is outside the popup
                            local px, py = popup.AbsolutePosition.X, popup.AbsolutePosition.Y
                            local pw, ph = popup.AbsoluteSize.X, popup.AbsoluteSize.Y
                            if mx < px or mx > px + pw or my < py or my > py + ph then
                                closePopup()
                            end
                        end)
                    end
                end)
                _attachHover(btn)

                function obj:SetValues(newVals)
                    self._items = {}
                    for _, v in ipairs(newVals) do self._items[#self._items+1] = v end
                    if isOpen then buildPopup() end
                end
                function obj:AddValue(v)    self._items[#self._items+1] = v; if isOpen then buildPopup() end end
                function obj:RemoveValue(v)
                    for i, s in ipairs(self._items) do
                        if s == v then table.remove(self._items, i); break end
                    end
                    if isOpen then buildPopup() end
                end
                function obj:SetValue(v)
                    if multi then self.Value = type(v)=="table" and v or {v}
                    else self.Value = v end
                    btn.Text = getDisplayText()
                    _fire(cb, self._cbs, self.Value)
                end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:GetValue()    return self.Value end
                function obj:SetCallback(fn) cb = fn end
                _attachElementAPI(obj, wrap)
                local _baseRemove = obj.Remove
                function obj:Remove()
                    pcall(closePopup)
                    _baseRemove(self)
                end
                return obj
            end

            -- ──────────────────────────────────────────────────
            --  COLOR PICKER  (HSV square · hue bar · opacity · hex)
            -- ──────────────────────────────────────────────────
            function go:AddColorPicker(idx, opts)
                opts = opts or {}
                local text   = opts.Text    or idx
                local def    = opts.Default or Color3.fromRGB(255, 80, 120)
                local cb     = opts.Callback or function() end

                local obj = { Value = def, _cbs = {} }
                Options[idx] = obj

                local h2, s2, v2 = Color3.toHSV(def)
                local alpha     = opts.Transparency ~= nil and (1 - opts.Transparency) or 1.0

                local row = New("TextButton", {
                    Text             = "",
                    BackgroundColor3 = Theme.Element,
                    Size             = UDim2.new(1, 0, 0, 30),
                    BorderSizePixel  = 0,
                    ClipsDescendants = false,
                    Parent           = body,
                })
                Corner(row, 6)

                New("TextLabel", {
                    Text             = text,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Position         = UDim2.new(0, 10, 0, 0),
                    Size             = UDim2.new(1, -52, 1, 0),
                    ZIndex           = 2,
                    Parent           = row,
                })
                -- colour preview swatch
                local swatch = New("Frame", {
                    BackgroundColor3 = def,
                    Size             = UDim2.new(0, 26, 0, 18),
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, -8, 0.5, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = 2,
                    Parent           = row,
                })
                Corner(swatch, 4)
                Stroke(swatch, Theme.Border, 1)

                -- expanded panel
                local panel = nil
                local panelOpen = false
                local _panelConns = {}  -- UIS connections created per-panel; cleaned on close

                local function getColor()
                    return Color3.fromHSV(h2, s2, v2)
                end
                local function applyColor()
                    local c = getColor()
                    obj.Value = c
                    swatch.BackgroundColor3 = c
                    _fire(cb, obj._cbs, c, alpha)
                end

                local function buildPanel()
                    -- Disconnect stale UIS connections from the previous panel
                    for _, c in ipairs(_panelConns) do pcall(function() c:Disconnect() end) end
                    _panelConns = {}
                    if panel then panel:Destroy(); panel = nil end
                    -- Parent to sg (ScreenGui) so the ScrollingFrame column cannot clip it
                    local _rx = row.AbsolutePosition.X
                    local _ry = row.AbsolutePosition.Y + row.AbsoluteSize.Y + 4
                    local _rw = row.AbsoluteSize.X
                    -- Flip above the row if the panel would fall off the bottom of the screen
                    if _ry + 148 > sg.AbsoluteSize.Y then _ry = row.AbsolutePosition.Y - 148 - 4 end
                    panel = New("Frame", {
                        BackgroundColor3 = Theme.PanelAlt,
                        Size             = UDim2.new(0, _rw, 0, 148),
                        Position         = UDim2.new(0, _rx, 0, _ry),
                        BorderSizePixel  = 0,
                        ZIndex           = 10,
                        ClipsDescendants = false,
                        Parent           = sg,
                    })
                    Corner(panel, 8)
                    Stroke(panel, Theme.Border)

                    -- Alpha slider (vertical, left side, 4px from panel edge)
                    local alphaTrk = New("Frame", {
                        BackgroundColor3 = Theme.SliderTrack,
                        Size             = UDim2.new(0, 8, 0, 100),
                        Position         = UDim2.new(0, 4, 0, 8),
                        BorderSizePixel  = 0,
                        ZIndex           = 21,
                        ClipsDescendants = false,
                        Parent           = panel,
                    })
                    Corner(alphaTrk, 4)
                    -- top = opaque (white), bottom = transparent (dark)
                    local alphaGradInst = Instance.new("UIGradient")
                    alphaGradInst.Color = ColorSequence.new(Color3.new(1,1,1), Color3.new(0.15,0.15,0.15))
                    alphaGradInst.Rotation = 90
                    alphaGradInst.Parent = alphaTrk
                    -- knob: horizontal bar wider than the track
                    local alphaKnob = New("Frame", {
                        BackgroundColor3 = Color3.new(1,1,1),
                        Size             = UDim2.new(0, 14, 0, 4),
                        AnchorPoint      = Vector2.new(0.5, 0.5),
                        Position         = UDim2.new(0.5, 0, 1 - alpha, 0),
                        ZIndex           = 22,
                        Parent           = alphaTrk,
                    })
                    Corner(alphaKnob, 2)
                    Stroke(alphaKnob, Color3.new(0,0,0), 1, 0)

                    -- SV square (gradient simulation with two layered UIGradients)
                    local svSq = New("Frame", {
                        Size             = UDim2.new(0, _rw - 56, 0, 100),
                        Position         = UDim2.new(0, 20, 0, 8),
                        BorderSizePixel  = 0,
                        ZIndex           = 21,
                        Parent           = panel,
                    })
                    Corner(svSq, 4)
                    -- white→hue gradient (horizontal)
                    local svGrad = New("Frame", {
                        BackgroundColor3 = Color3.fromHSV(h2, 1, 1),
                        Size             = UDim2.new(1,0,1,0),
                        ZIndex           = 21,
                        Parent           = svSq,
                    })
                    Corner(svGrad, 4)
                    local svGE = Instance.new("UIGradient")
                    svGE.Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                        ColorSequenceKeypoint.new(1, Color3.fromHSV(h2, 1, 1))
                    }
                    svGE.Rotation = 0
                    svGE.Parent = svGrad
                    -- black overlay (vertical, transparent→black)
                    local svBlack = New("Frame", {
                        BackgroundColor3 = Color3.new(0,0,0),
                        BackgroundTransparency = 0,
                        Size             = UDim2.new(1,0,1,0),
                        ZIndex           = 22,
                        Parent           = svSq,
                    })
                    Corner(svBlack, 4)
                    local svBlackGE = Instance.new("UIGradient")
                    svBlackGE.Color = ColorSequence.new(Color3.new(1,1,1), Color3.new(0,0,0))
                    svBlackGE.Rotation = 270
                    svBlackGE.Transparency = NumberSequence.new{
                        NumberSequenceKeypoint.new(0, 1),
                        NumberSequenceKeypoint.new(1, 0),
                    }
                    svBlackGE.Parent = svBlack

                    -- SV cursor
                    local svCursor = New("Frame", {
                        BackgroundColor3 = Color3.new(1,1,1),
                        Size             = UDim2.new(0, 10, 0, 10),
                        AnchorPoint      = Vector2.new(0.5, 0.5),
                        Position         = UDim2.new(s2, 0, 1 - v2, 0),
                        BorderSizePixel  = 0,
                        ZIndex           = 23,
                        Parent           = svSq,
                    })
                    Corner(svCursor, 5)
                    Stroke(svCursor, Color3.new(0,0,0), 1, 0)

                    -- Hue bar
                    local hueBar = New("Frame", {
                        BackgroundColor3 = Color3.new(1,0,0),
                        Size             = UDim2.new(0, 12, 0, 100),
                        Position         = UDim2.new(0, _rw - 30, 0, 8),
                        BorderSizePixel  = 0,
                        ZIndex           = 21,
                        Parent           = panel,
                    })
                    Corner(hueBar, 4)
                    local hueGrad = Instance.new("UIGradient")
                    hueGrad.Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,   1, 1)),
                        ColorSequenceKeypoint.new(0.166, Color3.fromHSV(0.166,1,1)),
                        ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333,1,1)),
                        ColorSequenceKeypoint.new(0.5,   Color3.fromHSV(0.5, 1, 1)),
                        ColorSequenceKeypoint.new(0.666, Color3.fromHSV(0.666,1,1)),
                        ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833,1,1)),
                        ColorSequenceKeypoint.new(1,     Color3.fromHSV(1,   1, 1)),
                    }
                    hueGrad.Rotation = 90
                    hueGrad.Parent   = hueBar

                    -- Hue cursor
                    local hueCursor = New("Frame", {
                        BackgroundColor3 = Color3.new(1,1,1),
                        Size             = UDim2.new(1, 2, 0, 4),
                        AnchorPoint      = Vector2.new(0.5, 0.5),
                        Position         = UDim2.new(0.5, 0, h2, 0),
                        BorderSizePixel  = 0,
                        ZIndex           = 22,
                        Parent           = hueBar,
                    })
                    Corner(hueCursor, 2)

                    -- Hex input (full-width bottom bar)
                    local hexBox = New("TextBox", {
                        Text             = string.format("#%02X%02X%02X",
                            math.floor(def.R*255), math.floor(def.G*255), math.floor(def.B*255)),
                        Font             = Enum.Font.Code,
                        TextSize         = 11,
                        TextColor3       = Theme.Text,
                        BackgroundColor3 = Theme.Element,
                        Size             = UDim2.new(0, _rw - 38, 0, 22),
                        Position         = UDim2.new(0, 20, 0, 116),
                        BorderSizePixel  = 0,
                        ZIndex           = 21,
                        ClearTextOnFocus = true,
                        Parent           = panel,
                    })
                    Corner(hexBox, 4)
                    Pad(hexBox, 0, 0, 5, 5)

                    -- Update functions
                    local function updateHueMark()
                        Tween(hueCursor, { Position = UDim2.new(0.5, 0, h2, 0) }, 0.04)
                        -- update sv gradient hue
                        svGE.Color = ColorSequence.new{
                            ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                            ColorSequenceKeypoint.new(1, Color3.fromHSV(h2, 1, 1))
                        }
                        svGrad.BackgroundColor3 = Color3.fromHSV(h2, 1, 1)
                    end
                    local function updateSVMark()
                        Tween(svCursor, { Position = UDim2.new(s2, 0, 1 - v2, 0) }, 0.04)
                    end
                    local function updateHex()
                        local c = getColor()
                        hexBox.Text = string.format("#%02X%02X%02X",
                            math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
                    end

                    -- Drag on SV square
                    local svDrag = false
                    svSq.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then
                            svDrag = true
                            s2 = Clamp((i.Position.X - svSq.AbsolutePosition.X) / svSq.AbsoluteSize.X, 0, 1)
                            v2 = 1 - Clamp((i.Position.Y - svSq.AbsolutePosition.Y) / svSq.AbsoluteSize.Y, 0, 1)
                            updateSVMark(); updateHex(); applyColor()
                        end
                    end)
                    _panelConns[#_panelConns+1] = UIS.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then svDrag = false end
                    end)
                    _panelConns[#_panelConns+1] = UIS.InputChanged:Connect(function(i)
                        if svDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
                            s2 = Clamp((i.Position.X - svSq.AbsolutePosition.X) / svSq.AbsoluteSize.X, 0, 1)
                            v2 = 1 - Clamp((i.Position.Y - svSq.AbsolutePosition.Y) / svSq.AbsoluteSize.Y, 0, 1)
                            updateSVMark(); updateHex(); applyColor()
                        end
                    end)

                    -- Drag on hue bar
                    local hueDrag = false
                    hueBar.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then
                            hueDrag = true
                            h2 = Clamp((i.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                            updateHueMark(); updateHex(); applyColor()
                        end
                    end)
                    _panelConns[#_panelConns+1] = UIS.InputChanged:Connect(function(i)
                        if hueDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
                            h2 = Clamp((i.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                            updateHueMark(); updateHex(); applyColor()
                        end
                    end)
                    _panelConns[#_panelConns+1] = UIS.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then hueDrag = false end
                    end)

                    -- Alpha drag (vertical: top = opaque, bottom = transparent)
                    local alphaDrag = false
                    alphaTrk.InputBegan:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then
                            alphaDrag = true
                            alpha = 1 - Clamp((i.Position.Y - alphaTrk.AbsolutePosition.Y) / alphaTrk.AbsoluteSize.Y, 0, 1)
                            Tween(alphaKnob, { Position = UDim2.new(0.5, 0, 1 - alpha, 0) }, 0.04)
                            applyColor()
                        end
                    end)
                    _panelConns[#_panelConns+1] = UIS.InputChanged:Connect(function(i)
                        if alphaDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
                            alpha = 1 - Clamp((i.Position.Y - alphaTrk.AbsolutePosition.Y) / alphaTrk.AbsoluteSize.Y, 0, 1)
                            Tween(alphaKnob, { Position = UDim2.new(0.5, 0, 1 - alpha, 0) }, 0.04)
                            applyColor()
                        end
                    end)
                    _panelConns[#_panelConns+1] = UIS.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then alphaDrag = false end
                    end)

                    -- Hex input commit
                    hexBox.FocusLost:Connect(function()
                        local hex = hexBox.Text:gsub("#",""):gsub("[^%x]","")
                        if #hex == 6 then
                            local r = tonumber(hex:sub(1,2),16)/255
                            local g = tonumber(hex:sub(3,4),16)/255
                            local b = tonumber(hex:sub(5,6),16)/255
                            local ch = Color3.new(r, g, b)
                            h2, s2, v2 = Color3.toHSV(ch)
                            updateHueMark(); updateSVMark(); applyColor()
                        else
                            updateHex()
                        end
                    end)
                    updateHueMark(); updateSVMark()
                end

                local _cpOutsideConn
                local function _closePanelExternal()
                    panelOpen = false
                    for _, c in ipairs(_panelConns) do pcall(function() c:Disconnect() end) end
                    _panelConns = {}
                    if panel then panel:Destroy(); panel = nil end
                    Tween(row, { BackgroundColor3 = Theme.Element }, 0.08)
                    if _cpOutsideConn then _cpOutsideConn:Disconnect(); _cpOutsideConn = nil end
                end

                row.MouseButton1Click:Connect(function()
                    panelOpen = not panelOpen
                    if panelOpen then
                        buildPanel()
                        Tween(row, { BackgroundColor3 = Theme.ElementAct }, 0.08)
                        -- Close when user clicks outside the picker panel
                        _cpOutsideConn = UIS.InputBegan:Connect(function(i, gp)
                            if gp then return end
                            if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                            if not panel then
                                if _cpOutsideConn then _cpOutsideConn:Disconnect(); _cpOutsideConn = nil end
                                return
                            end
                            local px, py = panel.AbsolutePosition.X, panel.AbsolutePosition.Y
                            local pw, ph = panel.AbsoluteSize.X, panel.AbsoluteSize.Y
                            local mx, my = i.Position.X, i.Position.Y
                            -- Skip if click landed on the row itself (let row.MouseButton1Click handle toggle)
                            local rx, ry = row.AbsolutePosition.X, row.AbsolutePosition.Y
                            local rw, rh = row.AbsoluteSize.X, row.AbsoluteSize.Y
                            if mx >= rx and mx <= rx + rw and my >= ry and my <= ry + rh then return end
                            if mx < px or mx > px + pw or my < py or my > py + ph then
                                _closePanelExternal()
                            end
                        end)
                    else
                        for _, c in ipairs(_panelConns) do pcall(function() c:Disconnect() end) end
                        _panelConns = {}
                        if _cpOutsideConn then _cpOutsideConn:Disconnect(); _cpOutsideConn = nil end
                        if panel then panel:Destroy(); panel = nil end
                        Tween(row, { BackgroundColor3 = Theme.Element }, 0.08)
                    end
                end)
                row.MouseEnter:Connect(function() if not panelOpen then Tween(row, { BackgroundColor3 = Theme.ElementHov }, 0.08) end end)
                row.MouseLeave:Connect(function() if not panelOpen then Tween(row, { BackgroundColor3 = Theme.Element    }, 0.08) end end)

                function obj:SetValue(c)
                    self.Value = c; swatch.BackgroundColor3 = c
                    h2, s2, v2 = Color3.toHSV(c)
                    if panelOpen then buildPanel() end
                    _fire(cb, self._cbs, c, alpha)
                end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:GetValue()    return self.Value end
                function obj:GetAlpha()    return alpha end
                function obj:SetCallback(fn) cb = fn end
                _attachElementAPI(obj, row)
                local _baseRemove = obj.Remove
                function obj:Remove()
                    pcall(_closePanelExternal)
                    _baseRemove(self)
                end
                return obj
            end

            -- ──────────────────────────────────────────────────
            --  KEYBIND  (Toggle · Hold · Always)
            -- ──────────────────────────────────────────────────
            function go:AddKeybind(idx, opts)
                opts = opts or {}
                local text   = opts.Text    or idx
                local def    = opts.Default
                local mode   = opts.Mode    or "Toggle"  -- "Toggle" | "Hold" | "Always"
                local cb     = opts.Callback or function() end
                local noUI   = opts.NoUI    or false      -- hide row (overlay-only)

                local obj = {
                    Value    = def,
                    Enabled  = false,
                    _cbs     = {},
                    _mode    = mode,
                    _listening = false,
                }
                Options[idx] = obj

                local row = New("TextButton", {
                    Text             = "",
                    BackgroundColor3 = Theme.Element,
                    Size             = UDim2.new(1, 0, 0, 30),
                    Visible          = not noUI,
                    BorderSizePixel  = 0,
                    ClipsDescendants = true,
                    Parent           = body,
                })
                Corner(row, 6)

                New("TextLabel", {
                    Text             = text,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 12,
                    TextColor3       = Theme.Text,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    BackgroundTransparency = 1,
                    Position         = UDim2.new(0, 10, 0, 0),
                    Size             = UDim2.new(1, -100, 1, 0),
                    ZIndex           = 2,
                    Parent           = row,
                })

                local function keyName(k)
                    if not k then return "None" end
                    return k.Name
                end

                local keyLbl = New("TextButton", {
                    Text             = "[" .. keyName(def) .. "]",
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 11,
                    TextColor3       = Theme.Accent,
                    BackgroundColor3 = Theme.PanelAlt,
                    Size             = UDim2.new(0, 82, 0, 20),
                    AnchorPoint      = Vector2.new(1, 0.5),
                    Position         = UDim2.new(1, -6, 0.5, 0),
                    BorderSizePixel  = 0,
                    ZIndex           = 2,
                    Parent           = row,
                })
                Corner(keyLbl, 4)

                -- Click keylabel to rebind
                keyLbl.MouseButton1Click:Connect(function()
                    if obj._listening then return end
                    obj._listening = true
                    keyLbl.Text = "[...]"
                    Tween(keyLbl, { TextColor3 = Theme.Gold }, 0.08)
                    local conn
                    conn = UIS.InputBegan:Connect(function(i, gp)
                        if gp then return end
                        if i.UserInputType == Enum.UserInputType.Keyboard then
                            obj.Value = i.KeyCode
                        elseif i.UserInputType == Enum.UserInputType.MouseButton1 then
                            obj.Value = Enum.UserInputType.MouseButton1
                        elseif i.UserInputType == Enum.UserInputType.MouseButton2 then
                            obj.Value = Enum.UserInputType.MouseButton2
                        end
                        keyLbl.Text = "[" .. keyName(obj.Value) .. "]"
                        Tween(keyLbl, { TextColor3 = Theme.Accent }, 0.1)
                        obj._listening = false
                        conn:Disconnect()
                        -- re-register with overlay
                        Library:_registerKeybind(idx, obj.Value, function(state)
                            obj.Enabled = state
                            for _, f in ipairs(obj._cbs) do pcall(f, state) end
                            pcall(cb, state)
                        end, mode)
                    end)
                end)

                -- mode badge
                local modeLbl = New("TextLabel", {
                    Text             = mode:upper():sub(1,3),
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 8,
                    TextColor3       = Theme.MutedText,
                    BackgroundTransparency = 1,
                    AnchorPoint      = Vector2.new(0.5, 1),
                    Position         = UDim2.new(1, -6 - 41, 1, 1),
                    Size             = UDim2.new(0, 82, 0, 10),
                    ZIndex           = 2,
                    Parent           = row,
                })

                -- Register with overlay system
                if def then
                    Library:_registerKeybind(idx, def, function(state)
                        obj.Enabled = state
                        for _, f in ipairs(obj._cbs) do pcall(f, state) end
                        pcall(cb, state)
                    end, mode)
                end

                function obj:SetValue(k) obj.Value = k; keyLbl.Text = "[" .. keyName(k) .. "]" end
                function obj:GetValue()    return self.Value end
                function obj:GetState() return self.Enabled end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:SetCallback(fn) cb = fn end
                _attachElementAPI(obj, row)
                return obj
            end

