-- ── File System Helpers ───────────────────────────────────────
local function SafeWrite(path, data)
    pcall(function() if typeof(writefile) == "function" then writefile(path, data) end end)
end
local function SafeRead(path)
    local ok, d = pcall(function() if typeof(readfile) == "function" and isfile(path) then return readfile(path) end end)
    return ok and d or nil
end
local function SafeJSON(t)
    return HttpService and pcall(HttpService.JSONEncode, HttpService, t) and HttpService:JSONEncode(t) or "{}"
end
local function SafeParse(s)
    if not HttpService then return {} end
    local ok, t = pcall(function() return HttpService:JSONDecode(s) end)
    return ok and t or {}
end

