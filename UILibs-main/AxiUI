function Library:CreateWindow(opts)
    opts = opts or {}
    local title     = opts.Title or "AxiUI"
    local sub       = opts.SubTitle or ""
    local winSize   = opts.Size or UDim2.new(0, 600, 0, 420)
    local center    = opts.Center ~= false
    local autoShow  = opts.AutoShow ~= false
    local draggable = opts.Draggable ~= false
    local _tKey     = { v = opts.ToggleKey or Enum.KeyCode.RightShift }
    local winPos    = opts.Position or (center and UDim2.new(0.5, 0, 0.5, 0) or UDim2.new(0, 60, 0, 60))

    local _initAnchor = center and Vector2.new(0.5, 0.5) or Vector2.new(0, 0)
    if draggable then
        local vp = (workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize) or Vector2.new(1920, 1080)
        local pw = winSize.X.Scale * vp.X + winSize.X.Offset
        local ph = winSize.Y.Scale * vp.Y + winSize.Y.Offset
        local absX = winPos.X.Scale * vp.X + winPos.X.Offset - pw * _initAnchor.X
        local absY = winPos.Y.Scale * vp.Y + winPos.Y.Offset - ph * _initAnchor.Y
        _initAnchor = Vector2.new(0, 0)
        winPos = UDim2.new(0, math.floor(absX), 0, math.floor(absY))
    end

    local sg = New("ScreenGui", { Name = "AxiUI_" .. title, ResetOnSpawn = false, IgnoreGuiInset = true, DisplayOrder = 100, Enabled = autoShow, Parent = GetRoot() })
    local shadowWrap = New("Frame", { BackgroundTransparency = 1, AnchorPoint = _initAnchor, Position = winPos, Size = winSize, Parent = sg })
    
    local win = New("Frame", { Name = "Window", BackgroundColor3 = Theme.Background, Size = UDim2.new(1, 0, 1, 0), Parent = shadowWrap })
    Corner(win, 10); local winStroke = Stroke(win, Theme.Border, 1)

    local titleBar = New("Frame", { Name = "TitleBar", BackgroundColor3 = Theme.TitleLeft, Size = UDim2.new(1, 0, 0, 42), BorderSizePixel = 0, Parent = win })
    Corner(titleBar, 10)
    New("TextLabel", { Text = title .. (sub ~= "" and ("  ·  " .. sub) or ""), Font = Enum.Font.GothamBold, TextSize = 14, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -72, 1, 0), Parent = titleBar })

    local tabBar = New("Frame", { Name = "TabBar", BackgroundColor3 = Theme.PanelDeep, Size = UDim2.new(1, 0, 0, 34), Position = UDim2.new(0, 0, 0, 42), BorderSizePixel = 0, Parent = win })
    local tabScroll = New("ScrollingFrame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.X, ScrollBarThickness = 0, ScrollingDirection = Enum.ScrollingDirection.X, Parent = tabBar })
    List(tabScroll, 2, Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Center); Pad(tabScroll, 0, 0, 8, 8)

    local content = New("Frame", { Name = "Content", BackgroundTransparency = 1, ClipsDescendants = true, Position = UDim2.new(0, 0, 0, 76), Size = UDim2.new(1, 0, 1, -76), Parent = win })

    if draggable then Draggable(shadowWrap, titleBar) end

    local Win = { _sg = sg, _shadow = shadowWrap, _win = win, _content = content, _tabs = {}, _activeTab = nil, _lib = self }
    Win.__index = Win

    local _vis = autoShow
    function Win:SetVisible(v)
        _vis = v; sg.Enabled = v; shadowWrap.Visible = v
        if v then Tween(winStroke, { Color = Theme.Accent }, 0); task.delay(0.08, function() if _vis then Tween(winStroke, { Color = Theme.Border }, 0.5) end end) end
    end
    function Win:Toggle() if not Library.Unloaded then self:SetVisible(not _vis) end end
    self:_connect(UIS.InputBegan, function(i) if i.KeyCode == _tKey.v then Win:Toggle() end end)

    function Win:AddTab(name)
        local tab = { _name = name, _win = self, _elements = {} }
        
        local tBtn = New("TextButton", { Text = name, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = Theme.MutedText, BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.new(0, 0, 1, -6), AnchorPoint = Vector2.new(0, 0.5), Parent = tabScroll })
        Corner(tBtn, 5); Pad(tBtn, 0, 0, 12, 12)
        local tInd = New("Frame", { BackgroundColor3 = Theme.Accent, Size = UDim2.new(0, 0, 0, 2), Position = UDim2.new(0.5, 0, 1, 0), AnchorPoint = Vector2.new(0.5, 1), BorderSizePixel = 0, Parent = tBtn })

        local page = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Visible = false, Parent = content })
        Pad(page, 8, 8, 8, 8)
        
        local function makeCol(xPos, xSize)
            local sc = New("ScrollingFrame", { BackgroundTransparency = 1, ScrollBarThickness = 3, ScrollBarImageColor3 = Theme.Border, ScrollingDirection = Enum.ScrollingDirection.Y, CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y, Size = UDim2.new(xSize, -4, 1, -2), Position = UDim2.new(xPos, xPos == 0 and 0 or 4, 0, 0), BorderSizePixel = 0, Parent = page })
            List(sc, 6); return sc
        end
        tab._leftCol = makeCol(0, 0.5); tab._rightCol = makeCol(0.5, 0.5); tab._fullCol = tab._leftCol
        tab._page = page; tab._tBtn = tBtn; tab._tInd = tInd

        if #self._tabs == 0 then
            page.Visible = true; Tween(tBtn, { TextColor3 = Theme.Accent }, 0); Tween(tInd, { Size = UDim2.new(1, 0, 0, 2) }, 0); self._activeTab = tab
        end

        tBtn.MouseButton1Click:Connect(function()
            if self._activeTab and self._activeTab ~= tab then
                self._activeTab._page.Visible = false
                Tween(self._activeTab._tBtn, { TextColor3 = Theme.MutedText }, 0.1)
                Tween(self._activeTab._tInd, { Size = UDim2.new(0, 0, 0, 2) }, 0.1)
            end
            tab._page.Visible = true; self._activeTab = tab
            Tween(tBtn, { TextColor3 = Theme.Accent }, 0.12)
            Tween(tInd, { Size = UDim2.new(1, 0, 0, 2) }, 0.14, Enum.EasingStyle.Back)
        end)

        table.insert(self._tabs, tab)

        local function _newGroupbox(gbName, parent)
            local go = { __index = go }
            local wrap = New("Frame", { BackgroundColor3 = Theme.Panel, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BorderSizePixel = 0, Parent = parent })
            Corner(wrap, 8); Stroke(wrap, Theme.Border, 1)

            local hdr = New("Frame", { BackgroundColor3 = Theme.PanelAlt, Size = UDim2.new(1, 0, 0, 30), BorderSizePixel = 0, Parent = wrap })
            Corner(hdr, 8); New("Frame", { BackgroundColor3 = Theme.PanelAlt, Size = UDim2.new(1, 0, 0.5, 0), Position = UDim2.new(0, 0, 0.5, 0), BorderSizePixel = 0, Parent = hdr })
            New("TextLabel", { Text = gbName, Font = Enum.Font.GothamBold, TextSize = 11, TextColor3 = Theme.SubText, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(1, -18, 1, 0), Parent = hdr })

            local body = New("Frame", { BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 30), Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, Parent = wrap })
            Pad(body, 6, 8, 8, 8); List(body, 5)

            go._wrap = wrap; go._body = body

            function go:AddToggle(idx, opts)
                opts = opts or {}
                local default = opts.Default ~= nil and opts.Default or false
                local cb = opts.Callback or function() end
                local obj = { Value = default, _cbs = {} }; Toggles[idx] = obj

                local row = New("TextButton", { Text = "", BackgroundColor3 = Theme.Element, Size = UDim2.new(1, 0, 0, 30), BorderSizePixel = 0, Parent = body })
                Corner(row, 6); _attachHover(row)
                New("TextLabel", { Text = opts.Text or idx, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Position = UDim2.new(0, 10, 0, 0), Size = UDim2.new(1, -58, 1, 0), Parent = row })
                
                local track = New("Frame", { BackgroundColor3 = default and Theme.ToggleOn or Theme.ToggleOff, Size = UDim2.new(0, 36, 0, 18), AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -10, 0.5, 0), BorderSizePixel = 0, Parent = row })
                Corner(track, 9); local sk = Stroke(track, default and Theme.AccentDim or Theme.Border, 1)
                local knob = New("Frame", { BackgroundColor3 = default and Theme.AccentGlow or Theme.SubText, Size = UDim2.new(0, 13, 0, 13), AnchorPoint = Vector2.new(0, 0.5), Position = default and UDim2.new(0, 21, 0.5, 0) or UDim2.new(0, 2, 0.5, 0), BorderSizePixel = 0, Parent = track })
                Corner(knob, 7)

                local function setVisual(v)
                    Tween(track, { BackgroundColor3 = v and Theme.ToggleOn or Theme.ToggleOff }, 0.14)
                    Tween(knob, { BackgroundColor3 = v and Theme.AccentGlow or Theme.SubText, Position = v and UDim2.new(0, 21, 0.5, 0) or UDim2.new(0, 2, 0.5, 0) }, 0.14, Enum.EasingStyle.Back)
                    if sk then Tween(sk, { Color = v and Theme.AccentDim or Theme.Border }, 0.14) end
                end

                row.MouseButton1Click:Connect(function() obj.Value = not obj.Value; setVisual(obj.Value); _fire(cb, obj._cbs, obj.Value) end)
                function obj:SetValue(v) self.Value = v; setVisual(v); _fire(cb, self._cbs, v) end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                return obj
            end

            function go:AddSlider(idx, opts)
                opts = opts or {}
                local min_, max_, default, rounding = opts.Min or 0, opts.Max or 100, opts.Default or (opts.Min or 0), opts.Rounding or 0
                local cb = opts.Callback or function() end
                local obj = { Value = Round(default, rounding), _cbs = {} }; Options[idx] = obj

                local wrap = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 46), Parent = body })
                local topRow = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 18), Parent = wrap })
                New("TextLabel", { Text = opts.Text or idx, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Size = UDim2.new(1, -70, 1, 0), Parent = topRow })
                local valBox = New("TextBox", { Text = tostring(obj.Value), Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = Theme.Accent, TextXAlignment = Enum.TextXAlignment.Right, BackgroundTransparency = 1, Size = UDim2.new(0, 66, 1, 0), Position = UDim2.new(1, -66, 0, 0), Parent = topRow })

                local track = New("Frame", { BackgroundColor3 = Theme.SliderTrack, Size = UDim2.new(1, 0, 0, 8), Position = UDim2.new(0, 0, 0, 26), BorderSizePixel = 0, Parent = wrap })
                Corner(track, 4); Stroke(track, Theme.Border, 1)
                
                local rel0 = (default - min_) / (max_ - min_)
                local fill = New("Frame", { BackgroundColor3 = Theme.SliderFill, Size = UDim2.new(rel0, 0, 1, 0), BorderSizePixel = 0, Parent = track })
                Corner(fill, 4)
                local knob = New("Frame", { BackgroundColor3 = Theme.SliderKnob, Size = UDim2.new(0, 16, 0, 16), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(rel0, 0, 0.5, 0), Parent = track })
                Corner(knob, 8); Stroke(knob, Theme.Border, 1)

                local function setFromRel(rel)
                    rel = Clamp(rel, 0, 1)
                    local v = Clamp(Round(min_ + rel * (max_ - min_), rounding), min_, max_)
                    local r = (v - min_) / (max_ - min_)
                    obj.Value = v; valBox.Text = tostring(v)
                    Tween(fill, { Size = UDim2.new(r, 0, 1, 0) }, 0.04); Tween(knob, { Position = UDim2.new(r, 0, 0.5, 0) }, 0.04)
                    _fire(cb, obj._cbs, v)
                end

                local dragging = false
                track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; setFromRel((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X) end end)
                Library:_connect(UIS.InputEnded, function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
                Library:_connect(UIS.InputChanged, function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then setFromRel((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X) end end)
                
                function obj:SetValue(v) local r = (Clamp(Round(v, rounding), min_, max_) - min_) / (max_ - min_); self.Value = Clamp(Round(v, rounding), min_, max_); Tween(fill, { Size = UDim2.new(r, 0, 1, 0) }, 0.1); Tween(knob, { Position = UDim2.new(r, 0, 0.5, 0) }, 0.1); valBox.Text = tostring(self.Value); _fire(cb, self._cbs, self.Value) end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                return obj
            end

            -- Extend with AddButton, AddInput, AddDropdown using similar condensed standard implementations.
            
            setmetatable(go, go)
            return go
        end

        function tab:AddLeftGroupbox(name) return _newGroupbox(name, tab._leftCol) end
        function tab:AddRightGroupbox(name) return _newGroupbox(name, tab._rightCol) end
        setmetatable(tab, tab)
        return tab
    end

    table.insert(self._windows, Win)
    setmetatable(Win, Win)
    return Win
end

return Library
