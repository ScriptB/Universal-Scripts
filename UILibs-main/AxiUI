local function PlaySound(id, vol, pitch)
    if not id or id == 0 then return end
    pcall(function()
        local s = Instance.new("Sound")
        s.SoundId = "rbxassetid://" .. tostring(id); s.Volume = vol or 0.5; s.PlaybackSpeed = pitch or 1
        if SoundService then s.Parent = SoundService end
        s:Play()
        if Debris then Debris:AddItem(s, 3) else task.delay(3, function() pcall(function() s:Destroy() end) end) end
    end)
end

local function GetRoot()
    local ok, r = pcall(function() if typeof(gethui) == "function" then return gethui() end return CoreGui end)
    if ok and r then return r end
    local ok2, cg = pcall(function() return game.CoreGui end)
    return ok2 and cg or game:GetService("CoreGui")
end

-- ── Draggable ─────────────────────────────────────────────────
local _rawSet = (pcall(function() return setrawproperty end) and typeof(setrawproperty) == "function") and setrawproperty or nil
local function _safeSetPos(f, p) if _rawSet then _rawSet(f, "Position", p) else f.Position = p end end

local function Draggable(frame, handle, cutoff)
    handle = handle or frame; cutoff = cutoff or (handle == frame and 40 or math.huge)
    frame.Active = true; handle.Active = true
    local dragging, dragInput, dragStartMX, dragStartMY, dragStartPos = false, nil, 0, 0, nil
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local mX, mY = input.Position.X, input.Position.Y
        if mY - frame.AbsolutePosition.Y > cutoff then return end
        dragStartMX, dragStartMY, dragStartPos = mX, mY, frame.Position
        dragging = true
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false; dragInput = nil end end)
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local deltaX, deltaY = input.Position.X - dragStartMX, input.Position.Y - dragStartMY
            _safeSetPos(frame, UDim2.new(dragStartPos.X.Scale, dragStartPos.X.Offset + deltaX, dragStartPos.Y.Scale, dragStartPos.Y.Offset + deltaY))
        end
    end)
end

local function MakeRipple(parent, x, y, col)
    local rip = New("Frame", { BackgroundColor3 = col or Theme.Accent, BackgroundTransparency = 0.6, Size = UDim2.new(0,0,0,0), Position = UDim2.new(0, x, 0, y), AnchorPoint = Vector2.new(0.5, 0.5), BorderSizePixel = 0, ZIndex = 10, Parent = parent })
    Corner(rip, 100)
    local targetSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.5
    Tween(rip, { Size = UDim2.new(0, targetSize, 0, targetSize), BackgroundTransparency = 1 }, 0.4, Enum.EasingStyle.Sine)
    task.delay(0.45, function() pcall(function() rip:Destroy() end) end)
end

