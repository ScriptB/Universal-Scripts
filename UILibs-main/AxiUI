local Library = {}
Library.__index = Library
Library._VERSION               = "3.0.0"
Library._connections           = {}
Library._windows               = {}
Library._unloadFns             = {}
Library._keybinds              = {}
Library._keybindListenersReady = false
Library.Unloaded               = false
Library._theme                 = Theme      -- active theme reference
Library._configFolder          = "AxiUI"
Library.Sounds                 = _sounds   -- configure sound IDs here

function Library:GetVersion() return self._VERSION end

function Library:_connect(sig, fn)
    local c = sig:Connect(fn)
    table.insert(self._connections, c)
    return c
end

function Library:OnUnload(fn)
    table.insert(self._unloadFns, fn)
end

function Library:Unload()
    self.Unloaded = true
    for _, fn in ipairs(self._unloadFns) do pcall(fn) end
    for _, c  in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
    for _, w  in ipairs(self._windows) do
        pcall(function() w._sg:Destroy() end)
    end
    if self._notifSG   then pcall(function() self._notifSG:Destroy()    end) end
    if self._wmSG      then pcall(function() self._wmSG:Destroy()       end) end
    if self._kbSG      then pcall(function() self._kbSG:Destroy()       end) end
end

