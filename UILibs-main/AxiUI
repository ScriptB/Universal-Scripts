            function go:AddRadioGroup(idx, opts)
                opts = opts or {}
                local text    = opts.Text    or idx
                local items   = opts.Items   or {}
                local def     = opts.Default
                local cb      = opts.Callback or function() end

                local obj = { Value = def, _cbs = {} }
                Options[idx] = obj

                local wrap = New("Frame", {
                    BackgroundTransparency = 1,
                    Size             = UDim2.new(1, 0, 0, 0),
                    AutomaticSize    = Enum.AutomaticSize.Y,
                    Parent           = body,
                })
                List(wrap, 3)

                -- header label
                if text and text ~= "" then
                    New("TextLabel", {
                        Text             = text,
                        Font             = Enum.Font.Gotham,
                        TextSize         = 12,
                        TextColor3       = Theme.Text,
                        TextXAlignment   = Enum.TextXAlignment.Left,
                        BackgroundTransparency = 1,
                        Size             = UDim2.new(1, 0, 0, 18),
                        Parent           = wrap,
                    })
                end

                local radioRows = {}
                local function setVisual(selected)
                    for _, rr in ipairs(radioRows) do
                        local isSel = rr.value == selected
                        Tween(rr.dot, {
                            BackgroundColor3 = isSel and Theme.Accent or Theme.MutedText,
                            Size = isSel and UDim2.new(0, 10, 0, 10) or UDim2.new(0, 6, 0, 6),
                        }, 0.12, Enum.EasingStyle.Back)
                        Tween(rr.ring, {
                            BackgroundColor3 = isSel and Theme.Accent or Theme.ToggleOff,
                        }, 0.12)
                        Tween(rr.lbl, { TextColor3 = isSel and Theme.Text or Theme.SubText }, 0.08)
                    end
                end

                for _, item in ipairs(items) do
                    local rRow = New("TextButton", {
                        Text             = "",
                        BackgroundColor3 = Theme.Element,
                        Size             = UDim2.new(1, 0, 0, 26),
                        BorderSizePixel  = 0,
                        Parent           = wrap,
                    })
                    Corner(rRow, 5)
                    _attachHover(rRow)

                    local ring = New("Frame", {
                        BackgroundColor3 = item == def and Theme.Accent or Theme.ToggleOff,
                        Size             = UDim2.new(0, 16, 0, 16),
                        AnchorPoint      = Vector2.new(0, 0.5),
                        Position         = UDim2.new(0, 8, 0.5, 0),
                        BorderSizePixel  = 0,
                        ZIndex           = 2,
                        Parent           = rRow,
                    })
                    Corner(ring, 8)
                    Stroke(ring, Theme.Border, 1)

                    local rdot = New("Frame", {
                        BackgroundColor3 = item == def and Theme.Accent or Theme.MutedText,
                        Size             = item == def and UDim2.new(0, 10, 0, 10) or UDim2.new(0, 6, 0, 6),
                        AnchorPoint      = Vector2.new(0.5, 0.5),
                        Position         = UDim2.new(0.5, 0, 0.5, 0),
                        BorderSizePixel  = 0,
                        ZIndex           = 3,
                        Parent           = ring,
                    })
                    Corner(rdot, 5)

                    local rlbl = New("TextLabel", {
                        Text             = tostring(item),
                        Font             = Enum.Font.Gotham,
                        TextSize         = 12,
                        TextColor3       = item == def and Theme.Text or Theme.SubText,
                        TextXAlignment   = Enum.TextXAlignment.Left,
                        BackgroundTransparency = 1,
                        Position         = UDim2.new(0, 30, 0, 0),
                        Size             = UDim2.new(1, -34, 1, 0),
                        ZIndex           = 2,
                        Parent           = rRow,
                    })

                    table.insert(radioRows, { value = item, dot = rdot, ring = ring, lbl = rlbl, row = rRow })

                    rRow.MouseButton1Click:Connect(function()
                        if obj.Value == item then return end
                        obj.Value = item
                        setVisual(item)
                        _fire(cb, obj._cbs, item)
                    end)
                end

                setVisual(def)

                function obj:SetValue(v)
                    self.Value = v
                    setVisual(v)
                    _fire(cb, self._cbs, v)
                end
                function obj:OnChanged(fn) table.insert(self._cbs, fn) end
                function obj:GetValue()    return self.Value end
                _attachElementAPI(obj, wrap)
                return obj
            end

