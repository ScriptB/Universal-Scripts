local function safe_writefile(path, data)
    local ok, err = pcall(function()
        if typeof(writefile) == "function" then writefile(path, data) end
    end)
    return ok
end

local function safe_readfile(path)
    local ok, data = pcall(function()
        if typeof(readfile) == "function" and isfile(path) then return readfile(path) end
        return nil
    end)
    return ok and data or nil
end

local function safe_delfile(path)
    pcall(function() if typeof(delfile) == "function" and isfile(path) then delfile(path) end end)
end

local function safe_listfiles(folder)
    if typeof(listfiles) == "function" then
        local ok, files = pcall(function() return listfiles(folder) end)
        if ok and type(files) == "table" then return files end
    end
    return {}
end

--- ThemeManager: Handles saving, loading, deleting, and listing user themes.
